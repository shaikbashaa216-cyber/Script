[CmdletBinding()]
param(
    [string]$OutputDirectory = "C:\Temp\AD_Daily_Health",
    [bool]$IncludeReplicationText = $true,
    [switch]$Runbook,
    [switch]$DemoMode,
    [ValidateRange(1, 25)]
    [int]$DemoDomainControllerLimit = 3,
    [ValidateRange(1, 50)]
    [int]$MaxConcurrency = 25,
    [ValidateRange(1, 24)]
    [int]$EventLookbackHours = 1
)

$ErrorActionPreference = 'Stop'
Set-StrictMode -Version 2.0

#region Functions

function Write-Log {
    param(
        [string]$Message,
        [string]$Level = 'INFO'
    )
    $ts = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'
    $color = switch ($Level) {
        'ERROR' { 'Red' }
        'WARN'  { 'Yellow' }
        'OK'    { 'Green' }
        default { 'White' }
    }
    Write-Host "[$ts] [$Level] $Message" -ForegroundColor $color
}

function HtmlSafe {
    param([object]$Value)
    if ($null -eq $Value) { return '' }
    return [System.Net.WebUtility]::HtmlEncode([string]$Value)
}

function Get-SvcBadge {
    param([string]$Status)
    $cls = if ($Status -eq 'Running') { 'svc-ok' } 
           elseif ($Status -eq 'Unknown') { 'svc-unk' } 
           else { 'svc-bad' }
    return "<span class='svc $cls'>$(HtmlSafe $Status)</span>"
}

function Test-Port {
    param(
        [string]$ComputerName,
        [int]$Port,
        [int]$TimeoutMs = 1000
    )
    try {
        $tcpClient = New-Object System.Net.Sockets.TcpClient
        $asyncResult = $tcpClient.BeginConnect($ComputerName, $Port, $null, $null)
        $wait = $asyncResult.AsyncWaitHandle.WaitOne($TimeoutMs)
        if ($wait) {
            $tcpClient.EndConnect($asyncResult)
            $tcpClient.Close()
            return $true
        }
        else {
            $tcpClient.Close()
            return $false
        }
    }
    catch {
        return $false
    }
}

function Get-DCServicesStatus {
    param(
        [string]$ComputerName,
        [int]$PortCheckTimeoutMs = 2000
    )
    
    # Required ports for DC communication
    $requiredPorts = @{
        "LDAP" = 389
        "LDAPS" = 636
        "GC" = 3268
        "GCSSL" = 3269
        "Kerberos" = 88
        "Kerberos-ChangePW" = 464
        "DNS" = 53
        "NetLogon" = 445
        "RPC" = 135
        "SMB" = 445
        "WinRM" = 5985
        "SecureWinRM" = 5986
        "Kpasswd" = 464
        "NTP" = 123
        "GlobalCatalog" = 3268
    }
    
    $portStatus = @{}
    foreach ($portName in $requiredPorts.Keys) {
        $portStatus[$portName] = Test-Port -ComputerName $ComputerName -Port $requiredPorts[$portName] -TimeoutMs $PortCheckTimeoutMs
    }
    
    # Method 1: Try Get-Service via WinRM (most reliable if enabled)
    $services = @{ NTDS = 'Unknown'; Netlogon = 'Unknown'; KDC = 'Unknown'; DFSR = 'Unknown'; DNS = 'Unknown' }
    $serviceError = $null
    $winrmAvailable = $portStatus["WinRM"] -or $portStatus["SecureWinRM"]
    
    if ($winrmAvailable) {
        try {
            $svcNames = @('NTDS', 'Netlogon', 'KDC', 'DFSR', 'DNS')
            $serviceQuery = @()
            foreach ($svc in $svcNames) {
                try {
                    $svcResult = Get-Service -ComputerName $ComputerName -Name $svc -ErrorAction Stop
                    $services[$svc] = $svcResult.Status.ToString()
                    $serviceQuery += $svcResult
                }
                catch {
                    $services[$svc] = 'Not Found'
                }
            }
        }
        catch {
            $serviceError = "WinRM query failed: $($_.Exception.Message)"
        }
    }
    
    # Method 2: Fallback to WMI/CIM if WinRM failed
    if ($services.Values | Where-Object { $_ -eq 'Unknown' -or $_ -eq 'Not Found' }) {
        try {
            $cimSession = New-CimSession -ComputerName $ComputerName -ErrorAction SilentlyContinue -OperationTimeoutSec 10
            if ($cimSession) {
                $cimServices = Get-CimInstance -CimSession $cimSession -ClassName Win32_Service -Filter "Name='NTDS' OR Name='Netlogon' OR Name='KDC' OR Name='DFSR' OR Name='DNS'" -ErrorAction SilentlyContinue
                foreach ($cimSvc in $cimServices) {
                    $services[$cimSvc.Name] = $cimSvc.State
                }
                Remove-CimSession $cimSession
            }
        }
        catch {
            if (-not $serviceError) { $serviceError = "CIM query failed: $($_.Exception.Message)" }
        }
    }
    
    # Method 3: Test service via SMB/RPC (check if service ports are responsive)
    if ($services.Values | Where-Object { $_ -eq 'Unknown' -or $_ -eq 'Not Found' }) {
        # Use service status based on port availability
        if ($portStatus["LDAP"] -and $portStatus["Kerberos"]) {
            if ($services["NTDS"] -eq 'Unknown') { $services["NTDS"] = 'Running' }
            if ($services["KDC"] -eq 'Unknown') { $services["KDC"] = 'Running' }
        }
        if ($portStatus["NetLogon"] -or $portStatus["SMB"]) {
            if ($services["Netlogon"] -eq 'Unknown') { $services["Netlogon"] = 'Running' }
        }
        if ($portStatus["DNS"]) {
            if ($services["DNS"] -eq 'Unknown') { $services["DNS"] = 'Running' }
        }
        # DFSR is harder to detect without WinRM, mark as unknown but not failed
        if ($services["DFSR"] -eq 'Unknown') { $services["DFSR"] = 'Unknown' }
    }
    
    return @{
        Services = $services
        Ports = $portStatus
        Error = $serviceError
        WinRMAvailable = $winrmAvailable
    }
}

function Write-HealthRunbook {
    $lines = @(
        'AD Daily Health Summary Runbook',
        '',
        'Required Ports for DC Communication:',
        '  - LDAP: 389, LDAPS: 636',
        '  - Global Catalog: 3268, 3269',
        '  - Kerberos: 88, 464',
        '  - DNS: 53',
        '  - NetLogon/SMB: 445',
        '  - WinRM: 5985 (HTTP), 5986 (HTTPS)',
        '  - RPC: 135',
        '  - NTP: 123',
        '',
        'Standard daily run:',
        'powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1',
        '',
        'Large environment with 200+ DCs:',
        'powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -MaxConcurrency 30 -EventLookbackHours 2',
        '',
        'Run without repadmin text block:',
        'powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -IncludeReplicationText:$false',
        '',
        'Demo mode:',
        'powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -DemoMode -DemoDomainControllerLimit 10',
        '',
        'Print this runbook only:',
        'powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -Runbook'
    )
    Write-Host ($lines -join [Environment]::NewLine)
}

# Event log collection function (runs on each DC)
function Get-DCEventLogs {
    param(
        [string]$ComputerName,
        [datetime]$StartTime,
        [int]$TimeoutSeconds = 60
    )
    
    $result = [pscustomobject]@{
        ComputerName = $ComputerName
        Success = $false
        ErrorMessage = $null
        AccountLockouts = @()           # 4740
        SuccessfulLogons = @()          # 4624
        Logoffs = @()                   # 4634, 4647
        FailedLogons = @()              # 4625
        UserAccountChanges = @()        # 4720, 4722, 4725, 4738
        PasswordChanges = @()           # 4723, 4724
        GroupMembershipChanges = @()    # 4728, 4732, 4756
        ADObjectChanges = @()           # 5136-5139
        AuditPolicyChanges = @()        # 4719
        SpecialLogon = @()              # 4672
        ExplicitCredentialLogon = @()   # 4648
        AccountUnlocked = @()           # 4767
        UnexpectedShutdown = @()        # 41, 6008
        PlannedRestart = @()            # 1074
        EventLogShutdown = @()          # 1100
        TotalEventsFound = 0
    }
    
    try {
        $scriptBlock = {
            param($Computer, $Start, $Timeout)
            
            $events = @{}
            $eventIds = @{
                AccountLockouts = 4740
                SuccessfulLogons = 4624
                Logoffs = @(4634, 4647)
                FailedLogons = 4625
                UserAccountChanges = @(4720, 4722, 4725, 4738)
                PasswordChanges = @(4723, 4724)
                GroupMembershipChanges = @(4728, 4732, 4756)
                ADObjectChanges = @(5136, 5137, 5138, 5139)
                AuditPolicyChanges = 4719
                SpecialLogon = 4672
                ExplicitCredentialLogon = 4648
                AccountUnlocked = 4767
                UnexpectedShutdown = @(41, 6008)
                PlannedRestart = 1074
                EventLogShutdown = 1100
            }
            
            $allIds = $eventIds.Values | ForEach-Object { $_ } | Sort-Object -Unique
            
            try {
                $filterHash = @{LogName='Security'; StartTime=$Start; ID=$allIds}
                $secEvents = Get-WinEvent -ComputerName $Computer -FilterHashtable $filterHash -ErrorAction Stop -MaxEvents 5000
                
                $filterHash = @{LogName='System'; StartTime=$Start; ID=$eventIds.UnexpectedShutdown + $eventIds.PlannedRestart + $eventIds.EventLogShutdown}
                $sysEvents = Get-WinEvent -ComputerName $Computer -FilterHashtable $filterHash -ErrorAction SilentlyContinue -MaxEvents 1000
                
                $allEvents = @($secEvents) + @($sysEvents)
            }
            catch {
                $allEvents = @()
            }
            
            $resultObj = @{
                AccountLockouts = @()
                SuccessfulLogons = @()
                Logoffs = @()
                FailedLogons = @()
                UserAccountChanges = @()
                PasswordChanges = @()
                GroupMembershipChanges = @()
                ADObjectChanges = @()
                AuditPolicyChanges = @()
                SpecialLogon = @()
                ExplicitCredentialLogon = @()
                AccountUnlocked = @()
                UnexpectedShutdown = @()
                PlannedRestart = @()
                EventLogShutdown = @()
                TotalEventsFound = 0
            }
            
            foreach ($evt in $allEvents) {
                $evtTime = $evt.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss')
                $evtId = $evt.Id
                $message = $evt.Message -replace "`n", ' ' -replace "`r", ' ' -replace ',', ';'
                $shortMsg = if ($message.Length -gt 200) { $message.Substring(0, 197) + '...' } else { $message }
                
                $eventObj = @{
                    Time = $evtTime
                    Id = $evtId
                    Message = $shortMsg
                }
                
                switch ($evtId) {
                    4740 { $resultObj.AccountLockouts += $eventObj }
                    4624 { $resultObj.SuccessfulLogons += $eventObj }
                    4634 { $resultObj.Logoffs += $eventObj }
                    4647 { $resultObj.Logoffs += $eventObj }
                    4625 { $resultObj.FailedLogons += $eventObj }
                    4720 { $resultObj.UserAccountChanges += $eventObj }
                    4722 { $resultObj.UserAccountChanges += $eventObj }
                    4725 { $resultObj.UserAccountChanges += $eventObj }
                    4738 { $resultObj.UserAccountChanges += $eventObj }
                    4723 { $resultObj.PasswordChanges += $eventObj }
                    4724 { $resultObj.PasswordChanges += $eventObj }
                    4728 { $resultObj.GroupMembershipChanges += $eventObj }
                    4732 { $resultObj.GroupMembershipChanges += $eventObj }
                    4756 { $resultObj.GroupMembershipChanges += $eventObj }
                    5136 { $resultObj.ADObjectChanges += $eventObj }
                    5137 { $resultObj.ADObjectChanges += $eventObj }
                    5138 { $resultObj.ADObjectChanges += $eventObj }
                    5139 { $resultObj.ADObjectChanges += $eventObj }
                    4719 { $resultObj.AuditPolicyChanges += $eventObj }
                    4672 { $resultObj.SpecialLogon += $eventObj }
                    4648 { $resultObj.ExplicitCredentialLogon += $eventObj }
                    4767 { $resultObj.AccountUnlocked += $eventObj }
                    41   { $resultObj.UnexpectedShutdown += $eventObj }
                    6008 { $resultObj.UnexpectedShutdown += $eventObj }
                    1074 { $resultObj.PlannedRestart += $eventObj }
                    1100 { $resultObj.EventLogShutdown += $eventObj }
                }
                $resultObj.TotalEventsFound++
            }
            
            return $resultObj
        }
        
        $job = Start-Job -ScriptBlock $scriptBlock -ArgumentList $ComputerName, $StartTime, $TimeoutSeconds
        $jobResult = $job | Wait-Job -Timeout $TimeoutSeconds | Receive-Job -ErrorAction SilentlyContinue
        
        if ($job.State -eq 'Running') {
            Stop-Job $job -ErrorAction SilentlyContinue
            $result.ErrorMessage = "Timeout after ${TimeoutSeconds} seconds"
        }
        elseif ($jobResult) {
            $result.Success = $true
            $result.AccountLockouts = $jobResult.AccountLockouts
            $result.SuccessfulLogons = $jobResult.SuccessfulLogons
            $result.Logoffs = $jobResult.Logoffs
            $result.FailedLogons = $jobResult.FailedLogons
            $result.UserAccountChanges = $jobResult.UserAccountChanges
            $result.PasswordChanges = $jobResult.PasswordChanges
            $result.GroupMembershipChanges = $jobResult.GroupMembershipChanges
            $result.ADObjectChanges = $jobResult.ADObjectChanges
            $result.AuditPolicyChanges = $jobResult.AuditPolicyChanges
            $result.SpecialLogon = $jobResult.SpecialLogon
            $result.ExplicitCredentialLogon = $jobResult.ExplicitCredentialLogon
            $result.AccountUnlocked = $jobResult.AccountUnlocked
            $result.UnexpectedShutdown = $jobResult.UnexpectedShutdown
            $result.PlannedRestart = $jobResult.PlannedRestart
            $result.EventLogShutdown = $jobResult.EventLogShutdown
            $result.TotalEventsFound = $jobResult.TotalEventsFound
            $result.ErrorMessage = $null
        }
        
        Remove-Job $job -Force -ErrorAction SilentlyContinue
    }
    catch {
        $result.ErrorMessage = $_.Exception.Message
    }
    
    return $result
}

# DC health check script (UPDATED with port-based service detection)
$dcCheckScript = {
    param([string]$HostName, [string]$Domain, [string]$Site, [string]$IPv4, [datetime]$EventStartTime, [int]$EventTimeout)
    
    $reachable = $false
    $pingLatencyMs = $null
    try { 
        $ping = Test-Connection -ComputerName $HostName -Count 1 -Quiet -ErrorAction Stop
        $reachable = $ping
        if ($reachable) {
            $pingDetail = Test-Connection -ComputerName $HostName -Count 1 -ErrorAction SilentlyContinue
            if ($pingDetail) { $pingLatencyMs = [int]$pingDetail.ResponseTime }
        }
    }
    catch { $reachable = $false }
    
    $services = @{ NTDS = 'Unknown'; Netlogon = 'Unknown'; KDC = 'Unknown'; DFSR = 'Unknown'; DNS = 'Unknown' }
    $portStatus = @{}
    $serviceError = ''
    $winrmAvailable = $false
    
    if ($reachable) {
        $svcStatus = Get-DCServicesStatus -ComputerName $HostName -PortCheckTimeoutMs 2000
        $services = $svcStatus.Services
        $portStatus = $svcStatus.Ports
        $winrmAvailable = $svcStatus.WinRMAvailable
        if ($svcStatus.Error) { $serviceError = $svcStatus.Error }
    }
    
    $anyBad = @($services.Values | Where-Object { $_ -notin @('Running', 'Unknown') })
    $dcStatus = if (-not $reachable) { 'Red' } elseif ($anyBad.Count -gt 0) { 'Yellow' } else { 'Green' }
    
    # Get events only if reachable
    $events = $null
    if ($reachable) {
        $events = Get-DCEventLogs -ComputerName $HostName -StartTime $EventStartTime -TimeoutSeconds $EventTimeout
    }
    
    [pscustomobject]@{
        Domain          = $Domain
        HostName        = $HostName
        Site            = $Site
        IPv4Address     = $IPv4
        Reachable       = $reachable
        PingLatencyMs   = $pingLatencyMs
        NTDS            = $services['NTDS']
        Netlogon        = $services['Netlogon']
        KDC             = $services['KDC']
        DFSR            = $services['DFSR']
        DNS             = $services['DNS']
        WinRMAvailable  = $winrmAvailable
        PortLDAP        = if ($portStatus.ContainsKey('LDAP')) { $portStatus['LDAP'] } else { $false }
        PortKerberos    = if ($portStatus.ContainsKey('Kerberos')) { $portStatus['Kerberos'] } else { $false }
        PortDNS         = if ($portStatus.ContainsKey('DNS')) { $portStatus['DNS'] } else { $false }
        PortSMB         = if ($portStatus.ContainsKey('SMB')) { $portStatus['SMB'] } else { $false }
        PortWinRM       = if ($portStatus.ContainsKey('WinRM')) { $portStatus['WinRM'] } else { $false }
        SvcError        = $serviceError
        DcStatus        = $dcStatus
        Events          = $events
    }
}

#endregion Functions

if ($Runbook) {
    Write-HealthRunbook
    return
}

#region Initialization

if (-not (Test-Path -LiteralPath $OutputDirectory)) {
    New-Item -ItemType Directory -Path $OutputDirectory -Force | Out-Null
}

Write-Log 'Loading ActiveDirectory module...'
Import-Module ActiveDirectory -ErrorAction Stop

$eventStartTime = (Get-Date).AddHours(-$EventLookbackHours)
Write-Log "Collecting events from last $EventLookbackHours hour(s) (since $eventStartTime)"

$stamp = Get-Date -Format 'yyyyMMdd_HHmmss'
$domain = Get-ADDomain
$forest = Get-ADForest
$dcs = @(Get-ADDomainController -Filter *)

if ($DemoMode -and $dcs.Count -gt $DemoDomainControllerLimit) {
    $dcs = @($dcs | Sort-Object HostName | Select-Object -First $DemoDomainControllerLimit)
    Write-Log ("Demo mode: limited to first {0} domain controllers." -f $DemoDomainControllerLimit)
}

#endregion Initialization

#region Parallel DC Health & Event Collection

Write-Log ("Starting parallel health and event collection: {0} DCs, max concurrency {1}..." -f $dcs.Count, $MaxConcurrency)

$pool = [System.Management.Automation.Runspaces.RunspaceFactory]::CreateRunspacePool(1, $MaxConcurrency)
$pool.Open()

$jobs = @()
foreach ($dc in $dcs) {
    $ps = [System.Management.Automation.PowerShell]::Create()
    $ps.RunspacePool = $pool
    [void]$ps.AddScript($dcCheckScript.ToString())
    [void]$ps.AddArgument([string]$dc.HostName)
    [void]$ps.AddArgument([string]$dc.Domain)
    [void]$ps.AddArgument([string]$dc.Site)
    [void]$ps.AddArgument([string]$dc.IPv4Address)
    [void]$ps.AddArgument([datetime]$eventStartTime)
    [void]$ps.AddArgument(60)
    $jobs += [pscustomobject]@{ PS = $ps; Handle = $ps.BeginInvoke(); HostName = $dc.HostName }
}

$dcRows = @()
$allEventData = @()
$done = 0
foreach ($job in $jobs) {
    $result = $job.PS.EndInvoke($job.Handle)
    if ($null -ne $result) { 
        $dcRows += $result
        if ($result.Events) {
            $allEventData += $result.Events
        }
    }
    $job.PS.Dispose()
    $done++
    if ($done % 20 -eq 0 -or $done -eq $jobs.Count) {
        Write-Log ("Progress: {0}/{1} DCs collected." -f $done, $jobs.Count)
    }
}

$pool.Close()
$pool.Dispose()
Write-Log ("Parallel collection complete. {0} results." -f $dcRows.Count)

# Count DCs with service detection issues
$dcsWithServiceIssues = @($dcRows | Where-Object { 
    $_.NTDS -eq 'Unavailable' -or $_.NTDS -eq 'Unknown' -or 
    $_.Netlogon -eq 'Unavailable' -or $_.Netlogon -eq 'Unknown'
})
Write-Log ("DCs with potential service detection issues: {0}" -f $dcsWithServiceIssues.Count) -Level WARN

# Aggregate events across all DCs
$aggregatedEvents = @{
    AccountLockouts = @()
    SuccessfulLogons = @()
    Logoffs = @()
    FailedLogons = @()
    UserAccountChanges = @()
    PasswordChanges = @()
    GroupMembershipChanges = @()
    ADObjectChanges = @()
    AuditPolicyChanges = @()
    SpecialLogon = @()
    ExplicitCredentialLogon = @()
    AccountUnlocked = @()
    UnexpectedShutdown = @()
    PlannedRestart = @()
    EventLogShutdown = @()
}

$totalEventsFound = 0
$dcsWithEventErrors = @()

foreach ($eventData in $allEventData) {
    if (-not $eventData.Success) {
        $dcsWithEventErrors += [pscustomobject]@{
            DC = $eventData.ComputerName
            Error = $eventData.ErrorMessage
        }
    }
    
    $totalEventsFound += $eventData.TotalEventsFound
    $aggregatedEvents.AccountLockouts += $eventData.AccountLockouts
    $aggregatedEvents.SuccessfulLogons += $eventData.SuccessfulLogons
    $aggregatedEvents.Logoffs += $eventData.Logoffs
    $aggregatedEvents.FailedLogons += $eventData.FailedLogons
    $aggregatedEvents.UserAccountChanges += $eventData.UserAccountChanges
    $aggregatedEvents.PasswordChanges += $eventData.PasswordChanges
    $aggregatedEvents.GroupMembershipChanges += $eventData.GroupMembershipChanges
    $aggregatedEvents.ADObjectChanges += $eventData.ADObjectChanges
    $aggregatedEvents.AuditPolicyChanges += $eventData.AuditPolicyChanges
    $aggregatedEvents.SpecialLogon += $eventData.SpecialLogon
    $aggregatedEvents.ExplicitCredentialLogon += $eventData.ExplicitCredentialLogon
    $aggregatedEvents.AccountUnlocked += $eventData.AccountUnlocked
    $aggregatedEvents.UnexpectedShutdown += $eventData.UnexpectedShutdown
    $aggregatedEvents.PlannedRestart += $eventData.PlannedRestart
    $aggregatedEvents.EventLogShutdown += $eventData.EventLogShutdown
}

Write-Log "Total security/audit events collected: $totalEventsFound"

#endregion Parallel DC Health & Event Collection

#region AD Data Collection (FSMO, Replication, Groups)

$fsmoMap = [ordered]@{
    PDCEmulator          = [string]$domain.PDCEmulator
    RIDMaster            = [string]$domain.RIDMaster
    InfrastructureMaster = [string]$domain.InfrastructureMaster
    SchemaMaster         = [string]$forest.SchemaMaster
    DomainNamingMaster   = [string]$forest.DomainNamingMaster
}

$fsmoRows = @()
foreach ($role in $fsmoMap.GetEnumerator()) {
    $ok = $false
    try { $ok = [bool](Test-Connection -ComputerName $role.Value -Count 1 -Quiet -ErrorAction Stop) } catch {}
    $fsmoRows += [pscustomobject]@{ Role = $role.Key; Holder = $role.Value; Reachable = $ok }
}

$replFailureRows = @()
try {
    $replFailures = @(Get-ADReplicationFailure -Scope Forest -ErrorAction Stop)
    foreach ($f in $replFailures) {
        $replFailureRows += [pscustomobject]@{
            Server           = [string]$f.Server
            Partner          = [string]$f.Partner
            LastError        = [string]$f.LastError
            FailureCount     = [int]$f.FailureCount
            FirstFailureTime = $f.FirstFailureTime
            LastFailureTime  = $f.LastFailureTime
        }
    }
}
catch { Write-Log ("Get-ADReplicationFailure: {0}" -f $_.Exception.Message) -Level WARN }

$replText = ''
if ($IncludeReplicationText -and (Get-Command repadmin.exe -ErrorAction SilentlyContinue)) {
    try { $replText = (& repadmin.exe /replsummary | Out-String) }
    catch { $replText = "repadmin failed: $($_.Exception.Message)" }
}

$privGroups = @('Domain Admins', 'Enterprise Admins', 'Schema Admins', 'Administrators', 'DNSAdmins')
$memberRows = @()
foreach ($group in $privGroups) {
    try {
        $members = @(Get-ADGroupMember -Identity $group -Recursive -ErrorAction Stop)
        foreach ($m in $members) {
            $memberRows += [pscustomobject]@{
                PrivilegedGroup   = $group
                MemberName        = [string]$m.Name
                MemberSam         = [string]$m.SamAccountName
                MemberClass       = [string]$m.objectClass
                DistinguishedName = [string]$m.DistinguishedName
            }
        }
    }
    catch {
        $memberRows += [pscustomobject]@{
            PrivilegedGroup   = $group; MemberName = ''; MemberSam = ''
            MemberClass       = 'Error'; DistinguishedName = $_.Exception.Message
        }
    }
}

#endregion AD Data Collection

#region Health Scoring

$reachableCount   = @($dcRows | Where-Object { $_.Reachable }).Count
$unreachableCount = @($dcRows | Where-Object { -not $_.Reachable }).Count
$issueRows        = @($dcRows | Where-Object { $_.DcStatus -ne 'Green' })
$fsmoDown         = @($fsmoRows | Where-Object { -not $_.Reachable }).Count
$replIssueCount   = $replFailureRows.Count

# Critical event detection
$criticalEvents = @()
$criticalEvents += $aggregatedEvents.AccountLockouts.Count
$criticalEvents += $aggregatedEvents.FailedLogons.Count
$criticalEvents += $aggregatedEvents.GroupMembershipChanges.Count
$criticalEvents += $aggregatedEvents.UnexpectedShutdown.Count
$hasCriticalEvents = ($criticalEvents | Measure-Object -Sum).Sum -gt 0

$healthStatus = if ($unreachableCount -gt 0 -or $fsmoDown -gt 0) { 'Red' }
               elseif ($issueRows.Count -gt 0 -or $replIssueCount -gt 0 -or $hasCriticalEvents) { 'Yellow' }
               else { 'Green' }

$escalationGuidance = switch ($healthStatus) {
    'Red'    { 'IMMEDIATE ACTION: One or more domain controllers or FSMO role holders are unreachable. Run Emergency_AD_Delivery_Report.ps1 with -ReportProfile Emergency now.' }
    'Yellow' { 'ATTENTION: Service degradation, replication failures, or critical security events detected. Review the issues below. Escalate with Emergency_AD_Delivery_Report.ps1 if symptoms persist.' }
    default  { 'All domain controllers and FSMO role holders are healthy. No critical security events detected. Continue daily monitoring.' }
}

$siteStats = @($dcRows | Group-Object -Property Site | ForEach-Object {
    $sg     = @($_.Group)
    $sRed   = @($sg | Where-Object { $_.DcStatus -eq 'Red'    }).Count
    $sYel   = @($sg | Where-Object { $_.DcStatus -eq 'Yellow' }).Count
    $sGrn   = @($sg | Where-Object { $_.DcStatus -eq 'Green'  }).Count
    $sColor = if ($sRed -gt 0) { 'red' } elseif ($sYel -gt 0) { 'yellow' } else { 'green' }
    [pscustomobject]@{
        Site   = [string]$_.Name
        Total  = $sg.Count
        Red    = $sRed
        Yellow = $sYel
        Green  = $sGrn
        Color  = $sColor
    }
} | Sort-Object Color, Site)

#endregion Health Scoring

#region HTML Generation

$siteCardsHtml = (@($siteStats) | ForEach-Object {
    $statusLine = if ($_.Red -gt 0) { "$($_.Red) unreachable" }
                  elseif ($_.Yellow -gt 0) { "$($_.Yellow) service issue" }
                  else { 'All healthy' }
    $dcText = if ($_.Total -eq 1) { '1 DC' } else { "$($_.Total) DCs" }
    "<div class='site-card site-$($_.Color)'>" +
    "<div class='site-name'>$(HtmlSafe $_.Site)</div>" +
    "<div class='site-count'>$dcText</div>" +
    "<div class='site-status'>$statusLine</div></div>"
}) -join [Environment]::NewLine

$priorityHtml = if ($issueRows.Count -eq 0) {
    "<tr><td colspan='11'>No issues detected in this run.</td></tr>"
} else {
    (@($issueRows | Sort-Object DcStatus, Site, HostName) | ForEach-Object {
        $rc = if ($_.DcStatus -eq 'Red') { 'row-red' } else { 'row-yellow' }
        "<tr class='$rc'><td>$(HtmlSafe $_.Site)</td><td>$(HtmlSafe $_.HostName)</td>" +
        "<td>$(HtmlSafe $_.IPv4Address)</td><td style='text-align:center'>$(if($_.Reachable){'✓'}else{'✗'})</td>" +
        "<td>$(Get-SvcBadge $_.NTDS)</td><td>$(Get-SvcBadge $_.Netlogon)</td>" +
        "<td>$(Get-SvcBadge $_.KDC)</td><td>$(Get-SvcBadge $_.DFSR)</td><td>$(Get-SvcBadge $_.DNS)</td>" +
        "<td style='font-size:10px'>$(if($_.PortLDAP){'LDAP✓'}else{'LDAP✗'})<br>$(if($_.PortKerberos){'KRB✓'}else{'KRB✗'})</td></td>" +
        "<td style='font-size:10px'>$(if($_.PortDNS){'DNS✓'}else{'DNS✗'})<br>$(if($_.PortSMB){'SMB✓'}else{'SMB✗'})</td></td>" +
        "<td style='font-size:10px'>$(if($_.WinRMAvailable){'WinRM✓'}else{'WinRM✗'})</td></td>"
    }) -join [Environment]::NewLine
}

$fsmoHtml = (@($fsmoRows) | ForEach-Object {
    $rc   = if (-not $_.Reachable) { 'row-red' } else { '' }
    $icon = if ($_.Reachable) { "<span class='svc svc-ok'>Reachable</span>" } else { "<span class='svc svc-bad'>UNREACHABLE</span>" }
    "<tr class='$rc'><td>$(HtmlSafe $_.Role)</td><td>$(HtmlSafe $_.Holder)</td><td>$icon</td></tr>"
}) -join [Environment]::NewLine

$replFailHtml = if ($replFailureRows.Count -eq 0) {
    "<tr><td colspan='6'>No replication failures detected across the forest.</td></tr>"
} else {
    (@($replFailureRows | Sort-Object FailureCount -Descending) | ForEach-Object {
        "<tr class='row-yellow'><td>$(HtmlSafe $_.Server)</td><td>$(HtmlSafe $_.Partner)</td>" +
        "<td>$(HtmlSafe $_.LastError)</td><td>$(HtmlSafe $_.FailureCount)</td>" +
        "<td>$(HtmlSafe $_.FirstFailureTime)</td><td>$(HtmlSafe $_.LastFailureTime)</td></tr>"
    }) -join [Environment]::NewLine
}

# Function to format event tables
function Format-EventTable {
    param($Events, $Title, $Columns = @('Time', 'DC', 'Event ID', 'Message'))
    
    if ($Events.Count -eq 0) {
        return "<p><em>No $Title events found in the last $EventLookbackHours hour(s).</em></p>"
    }
    
    $rows = @()
    foreach ($evt in $Events | Select-Object -First 100) {
        $dc = if ($evt.DC) { $evt.DC } else { $evt.ComputerName }
        $rows += "<tr><td>$(HtmlSafe $evt.Time)</td><td>$(HtmlSafe $dc)</td><td style='text-align:center'>$($evt.Id)</td><td>$(HtmlSafe $evt.Message)</td></tr>"
    }
    
    $moreMsg = if ($Events.Count -gt 100) { "<p class='meta'>+ $($Events.Count - 100) more events (see CSV for full list)</p>" } else { "" }
    
    return @"
<h3>$Title ($($Events.Count) events)</h3>
<div style='overflow-x: auto; max-height: 400px;'>
<table class='event-table'>
<thead><tr><th>Time</th><th>DC</th><th>Event ID</th><th>Message</th></tr></thead>
<tbody>
$($rows -join [Environment]::NewLine)
</tbody>
</table>
</div>
$moreMsg
"@
}

$siteGroupHtml = (@($dcRows | Group-Object -Property Site | Sort-Object Name) | ForEach-Object {
    $siteName    = [string]$_.Name
    $safeId      = $siteName -replace '[^a-zA-Z0-9]', '_'
    $siteDcs     = @($_.Group | Sort-Object DcStatus, HostName)
    $sRed        = @($siteDcs | Where-Object { $_.DcStatus -eq 'Red'    }).Count
    $sYel        = @($siteDcs | Where-Object { $_.DcStatus -eq 'Yellow' }).Count
    $badgeColor  = if ($sRed -gt 0) { 'red' } elseif ($sYel -gt 0) { 'yellow' } else { 'green' }
    $badgeLabel  = if ($sRed -gt 0) { "Red ($sRed unreachable)" } elseif ($sYel -gt 0) { "Yellow ($sYel issue)" } else { 'Green' }
    $dcCountText = if ($siteDcs.Count -eq 1) { '1 DC' } else { "$($siteDcs.Count) DCs" }

    $rows = (@($siteDcs) | ForEach-Object {
        $rc        = switch ($_.DcStatus) { 'Red' { 'dc-row row-red' } 'Yellow' { 'dc-row row-yellow' } default { 'dc-row' } }
        $reachIcon = if ($_.Reachable) { "<span class='svc svc-ok'>&#10003;</span>" } else { "<span class='svc svc-bad'>&#10007;</span>" }
        $search    = ($_.HostName + ' ' + $_.IPv4Address + ' ' + $_.Site).ToLower()
        $pingInfo = if ($_.PingLatencyMs) { "$($_.PingLatencyMs)ms" } else { '-' }
        "<tr class='$rc' data-search='$(HtmlSafe $search)'>" +
        "<td>$(HtmlSafe $_.HostName)</td><td style='font-size:10px'>$pingInfo</td><td>$(HtmlSafe $_.IPv4Address)</td><td style='text-align:center'>$reachIcon</td>" +
        "<td>$(Get-SvcBadge $_.NTDS)</td><td>$(Get-SvcBadge $_.Netlogon)</td>" +
        "<td>$(Get-SvcBadge $_.KDC)</td><td>$(Get-SvcBadge $_.DFSR)</td><td>$(Get-SvcBadge $_.DNS)</td>" +
        "<td style='font-size:10px;text-align:center'>$(if($_.PortLDAP){'✓'}else{'✗'})<br>$(if($_.PortKerberos){'✓'}else{'✗'})</td>" +
        "<td style='font-size:10px;text-align:center'>$(if($_.PortDNS){'✓'}else{'✗'})<br>$(if($_.PortSMB){'✓'}else{'✗'})</td>" +
        "<td style='font-size:10px;text-align:center'>$(if($_.WinRMAvailable){'✓'}else{'✗'})</td></table>"
    }) -join [Environment]::NewLine

    $block  = "<div class='site-section'>"
    $block += "<div class='site-header' onclick='toggleSite(`"$safeId`")'>"
    $block += "<span class='badge badge-$badgeColor'>$badgeLabel</span>"
    $block += "<strong>$(HtmlSafe $siteName)</strong>"
    $block += "<span class='dc-count'>$dcCountText</span>"
    $block += "<span class='toggle-hint'>(click to expand)</span></div>"
    $block += "<div id='site-$safeId' class='site-table' style='display:none'>"
    $block += "<tr><thead>"
    $block += "<tr><th>DC</th><th>Ping</th><th>IP</th><th>Reach</th><th>NTDS</th><th>Netlogon</th><th>KDC</th><th>DFSR</th><th>DNS</th><th>LDAP/KRB</th><th>DNS/SMB</th><th>WinRM</th></tr>"
    $block += "</thead><tbody>$rows</tbody>}</div></div>"
    $block
}) -join [Environment]::NewLine

$privHtml = if ($memberRows.Count -eq 0) {
    "<tr><td colspan='4'>No privileged group members returned.</td></tr>"
} else {
    (@($memberRows | Select-Object -First 50) | ForEach-Object {
        "<tr><td style='font-weight:bold'>$(HtmlSafe $_.PrivilegedGroup)</td><td>$(HtmlSafe $_.MemberName)</td>" +
        "<td>$(HtmlSafe $_.MemberSam)</td><td>$(HtmlSafe $_.MemberClass)</td></tr>"
    }) -join [Environment]::NewLine
}

$healthLower = $healthStatus.ToLowerInvariant()
$healthRunExamples = @(
    'powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1',
    'powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -MaxConcurrency 30 -EventLookbackHours 2',
    'powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -IncludeReplicationText:$false'
)
$healthRunExamplesHtml = (@($healthRunExamples) | ForEach-Object { "<li><code>$(HtmlSafe $_)</code></li>" }) -join [Environment]::NewLine

# Required ports documentation HTML
$requiredPortsHtml = @"
<h3>Required Ports for Domain Controller Communication</h3>
<table style='width: auto; margin: 10px 0;'>
<thead><tr><th>Port</th><th>Protocol</th><th>Service</th><th>Purpose</th></tr></thead>
<tbody>
<tr><td>389</td><td>TCP/UDP</td><td>LDAP</td><td>Directory Service queries</td></tr>
<tr><td>636</td><td>TCP</td><td>LDAPS</td><td>Secure LDAP</td></tr>
<tr><td>3268</td><td>TCP</td><td>Global Catalog</td><td>Forest-wide searches</td></tr>
<tr><td>3269</td><td>TCP</td><td>Global Catalog SSL</td><td>Secure GC</td></tr>
<tr><td>88</td><td>TCP/UDP</td><td>Kerberos</td><td>Authentication</td></tr>
<tr><td>464</td><td>TCP/UDP</td><td>Kerberos Change PW</td><td>Password changes</td></tr>
<tr><td>53</td><td>TCP/UDP</td><td>DNS</td><td>Name resolution</td></tr>
<tr><td>445</td><td>TCP</td><td>SMB/NetLogon</td><td>NetLogon, SYSVOL access</td></tr>
<tr><td>135</td><td>TCP</td><td>RPC</td><td>Remote procedure calls</td></tr>
<tr><td>5985</td><td>TCP</td><td>WinRM HTTP</td><td>Remote management</td></tr>
<tr><td>5986</td><td>TCP</td><td>WinRM HTTPS</td><td>Secure remote management</td></tr>
</tbody>
</table>
"@

#endregion HTML Generation

#region Output Files

$htmlPath = Join-Path $OutputDirectory ("AD_Daily_Health_Summary_{0}.html" -f $stamp)
$dcCsv    = Join-Path $OutputDirectory ("AD_Daily_Health_DCs_{0}.csv"     -f $stamp)
$groupCsv = Join-Path $OutputDirectory ("AD_Daily_Health_Groups_{0}.csv"  -f $stamp)
$eventsCsv = Join-Path $OutputDirectory ("AD_Daily_Health_Events_{0}.csv"  -f $stamp)
$jsonPath = Join-Path $OutputDirectory ("AD_Daily_Health_Summary_{0}.json" -f $stamp)

$dcRows | Export-Csv -Path $dcCsv -NoTypeInformation -Encoding UTF8
$memberRows | Export-Csv -Path $groupCsv -NoTypeInformation -Encoding UTF8

# Export all events to CSV for analysis
$allEventsExport = @()
foreach ($evtData in $allEventData) {
    foreach ($evt in $evtData.AccountLockouts) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.SuccessfulLogons) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.Logoffs) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.FailedLogons) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.UserAccountChanges) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.PasswordChanges) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.GroupMembershipChanges) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.ADObjectChanges) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.AuditPolicyChanges) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.SpecialLogon) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.ExplicitCredentialLogon) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.AccountUnlocked) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.UnexpectedShutdown) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.PlannedRestart) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
    foreach ($evt in $evtData.EventLogShutdown) { $evt | Add-Member -NotePropertyName "DC" -NotePropertyValue $evtData.ComputerName -Force; $allEventsExport += $evt }
}
$allEventsExport | Export-Csv -Path $eventsCsv -NoTypeInformation -Encoding UTF8

#endregion Output Files

#region HTML Template

$html = @"
<!DOCTYPE html>
<html lang='en'>
<head>
<meta charset='UTF-8' />
<meta name='viewport' content='width=device-width, initial-scale=1.0' />
<title>AD Daily Health Summary with Security Events</title>
<style>
:root { --bg1:#eaf3ff; --bg2:#dbeafe; --panel:#ffffff; --border:#bfd6f6; --title:#0f2a56; --text:#16335f; --muted:#47678f; --head:#e1eeff; }
* { box-sizing: border-box; }
body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; padding: 16px; background: linear-gradient(160deg, var(--bg1) 0%, var(--bg2) 100%); color: var(--text); min-height: 100vh; }
h1, h2, h3 { margin: 0 0 8px 0; color: var(--title); }
.panel { background: var(--panel); border: 1px solid var(--border); border-radius: 12px; padding: 14px; margin-bottom: 14px; box-shadow: 0 3px 12px rgba(22,74,140,0.08); }
.meta { color: var(--muted); font-size: 13px; margin-top: 4px; }
.cards { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; }
.card { background: linear-gradient(180deg,#ffffff 0%,#f0f7ff 100%); border: 1px solid var(--border); border-radius: 12px; padding: 10px 16px; min-width: 130px; }
.k { font-size: 11px; text-transform: uppercase; color: var(--muted); letter-spacing: .05em; }
.v { font-size: 26px; font-weight: 700; color: var(--title); }
.badge { display: inline-block; padding: 3px 10px; border-radius: 999px; font-weight: 600; font-size: 12px; }
.badge-green  { background: #dcfce7; color: #166534; }
.badge-yellow { background: #fef3c7; color: #92400e; }
.badge-red    { background: #fee2e2; color: #991b1b; }
.esc { padding: 10px 14px; border-radius: 8px; font-weight: 500; }
.esc-green  { background: #f0fdf4; border-left: 4px solid #22c55e; color: #14532d; }
.esc-yellow { background: #fffbeb; border-left: 4px solid #f59e0b; color: #78350f; }
.esc-red    { background: #fef2f2; border-left: 4px solid #ef4444; color: #7f1d1d; }
.site-grid { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
.site-card { border-radius: 10px; padding: 10px 14px; min-width: 155px; }
.site-green  { background: #f0fdf4; border: 1px solid #86efac; }
.site-yellow { background: #fffbeb; border: 1px solid #fcd34d; }
.site-red    { background: #fef2f2; border: 1px solid #fca5a5; }
.site-name   { font-weight: 600; font-size: 13px; color: var(--title); }
.site-count  { font-size: 11px; color: var(--muted); }
.site-status { font-size: 12px; font-weight: 500; margin-top: 2px; }
.site-green  .site-status { color: #166534; }
.site-yellow .site-status { color: #92400e; }
.site-red    .site-status { color: #991b1b; }
.site-section { margin-bottom: 6px; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
.site-header { background: var(--head); padding: 9px 14px; cursor: pointer; display: flex; align-items: center; gap: 10px; user-select: none; }
.site-header:hover { background: #cde5ff; }
.dc-count    { color: var(--muted); font-size: 12px; }
.toggle-hint { color: var(--muted); font-size: 11px; margin-left: auto; }
.site-table  { padding: 0; }
table { border-collapse: collapse; width: 100%; font-size: 12px; background: #fff; }
th, td { border: 1px solid #d4e4fb; padding: 6px 8px; text-align: left; vertical-align: middle; }
th { background: var(--head); color: var(--title); font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
.event-table { font-size: 11px; }
.event-table td { max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.event-table td:last-child { white-space: normal; word-break: break-word; }
.cmd-list { margin: 8px 0 0 18px; }
.cmd-list li { margin: 5px 0; }
code { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 2px 6px; color: #1e3a8a; font-family: Consolas, 'Courier New', monospace; font-size: 12px; }
.row-red    td { background: #fff1f2; }
.row-yellow td { background: #fffbeb; }
.svc { display: inline-block; padding: 2px 7px; border-radius: 4px; font-size: 11px; font-weight: 500; }
.svc-ok  { background: #dcfce7; color: #166534; }
.svc-bad { background: #fee2e2; color: #991b1b; }
.svc-unk { background: #f1f5f9; color: #64748b; }
.search-bar { width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 13px; margin-bottom: 10px; color: var(--text); background: #fff; }
.search-bar:focus { outline: 2px solid #3b82f6; border-color: #3b82f6; }
pre { background: #0f172a; color: #e2e8f0; padding: 12px; border-radius: 8px; overflow-x: auto; font-size: 12px; line-height: 1.5; }
.tab-container { margin-bottom: 10px; }
.tab-buttons { display: flex; gap: 5px; border-bottom: 1px solid var(--border); margin-bottom: 10px; }
.tab-btn { padding: 8px 16px; background: var(--head); border: none; cursor: pointer; border-radius: 6px 6px 0 0; font-weight: 500; }
.tab-btn.active { background: var(--panel); border-bottom: 2px solid var(--title); }
.tab-content { display: none; }
.tab-content.active { display: block; }
</style>
</head>
<body>
<div class='panel'>
<h1>AD Daily Health & Security Summary</h1>
<div class='meta'>Generated: $(HtmlSafe (Get-Date -Format 'yyyy-MM-dd HH:mm:ss'))</div>
<div class='meta'>Domain: $(HtmlSafe $domain.DNSRoot) &nbsp;|&nbsp; Forest: $(HtmlSafe $forest.Name) &nbsp;|&nbsp; Domain Controllers: $($dcRows.Count) &nbsp;|&nbsp; AD Sites: $($siteStats.Count)</div>
<div class='meta'>Event Lookback: Last $EventLookbackHours hour(s) (starting $(HtmlSafe $eventStartTime))</div>
</div>

$requiredPortsHtml

<div class='cards'>
<div class='card'><div class='k'>Overall Health</div><div class='v'><span class='badge badge-$healthLower'>$(HtmlSafe $healthStatus)</span></div></div>
<div class='card'><div class='k'>Domain Controllers</div><div class='v'>$($dcRows.Count)</div></div>
<div class='card'><div class='k'>Reachable</div><div class='v'>$reachableCount</div></div>
<div class='card'><div class='k'>Unreachable</div><div class='v'>$unreachableCount</div></div>
<div class='card'><div class='k'>Service Issues</div><div class='v'>$($issueRows.Count)</div></div>
<div class='card'><div class='k'>Repl Failures</div><div class='v'>$replIssueCount</div></div>
<div class='card'><div class='k'>Total Events</div><div class='v'>$totalEventsFound</div></div>
</div>

<div class='panel'>
<div class='esc esc-$healthLower'>$(HtmlSafe $escalationGuidance)</div>
</div>

<div class='panel'>
<h2>How To Run This Script</h2>
<ul class='cmd-list'>
$healthRunExamplesHtml
</ul>
</div>

<div class='panel'>
<h2>Site Health Overview</h2>
<div class='site-grid'>
$siteCardsHtml
</div>
</div>

<div class='panel'>
<h2>Priority DC Issues</h2>
<table>
<thead>
<tr><th>Site</th><th>DC</th><th>IP</th><th>Reach</th><th>NTDS</th><th>Netlogon</th><th>KDC</th><th>DFSR</th><th>DNS</th><th>LDAP/KRB</th><th>DNS/SMB</th><th>WinRM</th></tr>
</thead>
<tbody>
$priorityHtml
</tbody>
</table>
</div>

<div class='panel'>
<h2>Security & Audit Events</h2>
<div class='meta'>Collected from last $EventLookbackHours hour(s). Full details in CSV: $(HtmlSafe $eventsCsv)</div>
<div class='tab-container'>
<div class='tab-buttons'>
<button class='tab-btn active' onclick='showTab("critical")'>⚠ Critical</button>
<button class='tab-btn' onclick='showTab("account")'>👤 Account</button>
<button class='tab-btn' onclick='showTab("system")'>🖥 System</button>
</div>
<div id='critical' class='tab-content active'>
$(Format-EventTable -Events $allEventsExport -Title "All Security Events")
</div>
<div id='account' class='tab-content'>
<h3>Account Lockouts ($($aggregatedEvents.AccountLockouts.Count))</h3>
$(if ($aggregatedEvents.AccountLockouts.Count -gt 0) { Format-EventTable -Events $aggregatedEvents.AccountLockouts -Title "" } else { "<p><em>None</em></p>" })
<h3>Failed Logons ($($aggregatedEvents.FailedLogons.Count))</h3>
$(if ($aggregatedEvents.FailedLogons.Count -gt 0) { Format-EventTable -Events $aggregatedEvents.FailedLogons -Title "" } else { "<p><em>None</em></p>" })
<h3>Group Membership Changes ($($aggregatedEvents.GroupMembershipChanges.Count))</h3>
$(if ($aggregatedEvents.GroupMembershipChanges.Count -gt 0) { Format-EventTable -Events $aggregatedEvents.GroupMembershipChanges -Title "" } else { "<p><em>None</em></p>" })
</div>
<div id='system' class='tab-content'>
<h3>Unexpected Shutdowns ($($aggregatedEvents.UnexpectedShutdown.Count))</h3>
$(if ($aggregatedEvents.UnexpectedShutdown.Count -gt 0) { Format-EventTable -Events $aggregatedEvents.UnexpectedShutdown -Title "" } else { "<p><em>None</em></p>" })
<h3>Planned Restarts ($($aggregatedEvents.PlannedRestart.Count))</h3>
$(if ($aggregatedEvents.PlannedRestart.Count -gt 0) { Format-EventTable -Events $aggregatedEvents.PlannedRestart -Title "" } else { "<p><em>None</em></p>" })
</div>
</div>
</div>

<div class='panel'>
<h2>FSMO Role Holders</h2>
<table>
<thead><tr><th>Role</th><th>Holder</th><th>Status</th></tr></thead>
<tbody>$fsmoHtml</tbody>
</table>
</div>

<div class='panel'>
<h2>Replication Failures</h2>
<table>
<thead><tr><th>Server</th><th>Partner</th><th>Last Error</th><th>Count</th><th>First Failure</th><th>Last Failure</th></tr></thead>
<tbody>$replFailHtml</tbody>
</table>
</div>

<div class='panel'>
<h2>All Domain Controllers by Site</h2>
<input class='search-bar' type='text' id='dcSearch' placeholder='Search by DC name, IP address, or site...' oninput='filterDCs(this.value)' />
$siteGroupHtml
</div>

<div class='panel'>
<h2>Privileged Group Membership</h2>
<div class='meta'>Total members: $($memberRows.Count) (first 50 shown)</div>
<table>
<thead><tr><th>Group</th><th>Member Name</th><th>SAM Account</th><th>Type</th></tr></thead>
<tbody>$privHtml</tbody>
</table>
</div>

<div class='panel'>
<h2>Replication Summary</h2>
<pre>$(HtmlSafe $replText)</pre>
</div>

<script>
function toggleSite(id) {
    var el = document.getElementById('site-' + id);
    if (el) { el.style.display = (el.style.display === 'none') ? '' : 'none'; }
}
function filterDCs(val) {
    var lower = val.toLowerCase().trim();
    var rows = document.querySelectorAll('.dc-row');
    rows.forEach(function(r) {
        var sd = r.getAttribute('data-search') || '';
        r.style.display = lower === '' ? '' : (sd.indexOf(lower) > -1 ? '' : 'none');
    });
}
function showTab(tabName) {
    var tabs = ['critical', 'account', 'system'];
    tabs.forEach(function(t) {
        var content = document.getElementById(t);
        var btn = document.querySelector('.tab-btn[onclick="showTab(\'' + t + '\')"]');
        if (t === tabName) {
            content.classList.add('active');
            if (btn) btn.classList.add('active');
        } else {
            content.classList.remove('active');
            if (btn) btn.classList.remove('active');
        }
    });
}
</script>
</body>
</html>
"@

[System.IO.File]::WriteAllText($htmlPath, $html, [System.Text.Encoding]::UTF8)

#endregion HTML Template

#region Final Output

Write-Log "=========================================" -Level OK
Write-Log "AD Daily Health Summary Complete!" -Level OK
Write-Log "=========================================" -Level OK
Write-Log ("HTML : {0}" -f $htmlPath) -Level OK
Write-Log ("CSV  : {0}" -f $dcCsv) -Level OK
Write-Log ("CSV  : {0}" -f $groupCsv) -Level OK
Write-Log ("CSV  : {0}" -f $eventsCsv) -Level OK
Write-Log ("JSON : {0}" -f $jsonPath) -Level OK
Write-Log "=========================================" -Level OK

[pscustomobject]@{
    HtmlReport = $htmlPath
    DcCsv      = $dcCsv
    GroupCsv   = $groupCsv
    EventsCsv  = $eventsCsv
    JsonReport = $jsonPath
}

#endregion Final Output

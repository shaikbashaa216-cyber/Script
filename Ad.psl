<#
.SYNOPSIS
    Active Directory Daily Health Check with Comprehensive Event Log Monitoring
    
.DESCRIPTION
    Performs daily health checks on Active Directory including DC health, FSMO roles,
    replication status, and critical security event log analysis. Outputs HTML dashboard.
    
    Features:
    - Choose scope: Full Forest, Current Domain, or Custom DC List
    - Improved service detection using WMI/CIM
    - Unexpected shutdown tracking with dedicated tab
    - Comprehensive event monitoring
    
    Monitored Event IDs:
    - 4625: Failed logon
    - 4719: System audit policy modified
    - 4672: Special privileges assigned
    - 4648: Explicit credential logon
    - 1100: Event log service shutdown
    - 6008: Unexpected shutdown
    - 1074: Planned restart/shutdown
    
.NOTES
    Run on a domain-joined server with ActiveDirectory module and admin privileges.
#>

[CmdletBinding()]
param(
    [Parameter(Mandatory = $false)]
    [string]$OutputDirectory = "C:\Temp\AD_Daily_Health",
    
    [Parameter(Mandatory = $false)]
    [ValidateSet('Forest', 'CurrentDomain', 'CustomDCList')]
    [string]$ScanScope = 'Forest',
    
    [Parameter(Mandatory = $false)]
    [string]$CustomDCListPath = "",
    
    [Parameter(Mandatory = $false)]
    [switch]$IncludeReplicationText = $true,
    
    [Parameter(Mandatory = $false)]
    [switch]$Runbook,
    
    [Parameter(Mandatory = $false)]
    [switch]$DemoMode,
    
    [Parameter(Mandatory = $false)]
    [ValidateRange(1, 25)]
    [int]$DemoDomainControllerLimit = 3,
    
    [Parameter(Mandatory = $false)]
    [ValidateRange(1, 168)]
    [int]$EventLookbackHours = 24,
    
    [Parameter(Mandatory = $false)]
    [switch]$SkipEventLogs,
    
    [Parameter(Mandatory = $false)]
    [int]$PortCheckTimeoutMs = 3000
)

$ErrorActionPreference = 'Continue'
$WarningPreference = 'SilentlyContinue'

# =============================================================================
# SECTION 1: LOGGING AND UTILITY FUNCTIONS
# =============================================================================

function Write-Log {
    param(
        [string]$Message,
        [string]$Level = 'INFO'
    )
    $ts = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'
    $color = switch ($Level) {
        'ERROR'   { 'Red' }
        'WARN'    { 'Yellow' }
        'OK'      { 'Green' }
        default   { 'Gray' }
    }
    Write-Host "[$ts] [$Level] $Message" -ForegroundColor $color
}

function Write-HealthRunbook {
    $lines = @(
        '═══════════════════════════════════════════════════════════════════════════════',
        '                    AD Daily Health Summary Runbook',
        '═══════════════════════════════════════════════════════════════════════════════',
        '',
        'SCAN SCOPE OPTIONS:',
        '  -Forest (default): Scans entire Active Directory forest',
        '  -CurrentDomain: Scans only the current domain',
        '  -CustomDCList: Scans DCs from a text file (one FQDN per line)',
        '',
        'EXAMPLES:',
        '  # Full forest scan',
        '  .\AD_Daily_Health_Summary.ps1',
        '',
        '  # Current domain only',
        '  .\AD_Daily_Health_Summary.ps1 -ScanScope CurrentDomain',
        '',
        '  # Custom DC list',
        '  .\AD_Daily_Health_Summary.ps1 -ScanScope CustomDCList -CustomDCListPath "C:\DCs.txt"',
        '',
        '  # Skip event logs',
        '  .\AD_Daily_Health_Summary.ps1 -SkipEventLogs',
        '',
        '  # Demo mode',
        '  .\AD_Daily_Health_Summary.ps1 -DemoMode -DemoDomainControllerLimit 10',
        '',
        '═══════════════════════════════════════════════════════════════════════════════'
    )
    Write-Host ($lines -join [Environment]::NewLine) -ForegroundColor Cyan
}

function HtmlSafe {
    param([object]$Value)
    if ($null -eq $Value) { return '' }
    try {
        return [System.Net.WebUtility]::HtmlEncode([string]$Value)
    }
    catch {
        return ''
    }
}

function Get-SvcBadge {
    param([string]$Status)
    $cls = if ($Status -eq 'Running') { 'svc-ok' } 
           elseif ($Status -eq 'Unknown') { 'svc-unk' } 
           else { 'svc-bad' }
    return "<span class='svc $cls'>$(HtmlSafe $Status)</span>"
}


# =============================================================================
# SECTION 2: SCOPE MANAGEMENT FUNCTIONS
# =============================================================================

function Get-TargetDomainControllers {
    param(
        [string]$Scope,
        [string]$CustomDCListPath
    )
    
    $dcs = @()
    
    switch ($Scope) {
        'Forest' {
            Write-Log "Scanning entire Active Directory Forest..." -Level OK
            try {
                $forest = Get-ADForest
                $domains = $forest.Domains
                Write-Log "Found $($domains.Count) domains in forest" -Level INFO
                
                foreach ($domain in $domains) {
                    Write-Log "Getting DCs from domain: $domain" -Level INFO
                    $domainDcs = @(Get-ADDomainController -Filter * -Server $domain -ErrorAction Stop)
                    $dcs += $domainDcs
                    Write-Log "  - Found $($domainDcs.Count) DCs in $domain" -Level INFO
                }
            }
            catch {
                $errMsg = $_.Exception.Message
                Write-Log "Failed to get forest DCs: $errMsg" -Level ERROR
                throw
            }
            break
        }
        
        'CurrentDomain' {
            Write-Log "Scanning current domain only..." -Level OK
            try {
                $currentDomain = (Get-ADDomain).DNSRoot
                Write-Log "Current domain: $currentDomain" -Level INFO
                $dcs = @(Get-ADDomainController -Filter * -ErrorAction Stop)
                Write-Log "Found $($dcs.Count) DCs in current domain" -Level INFO
            }
            catch {
                $errMsg = $_.Exception.Message
                Write-Log "Failed to get current domain DCs: $errMsg" -Level ERROR
                throw
            }
            break
        }
        
        'CustomDCList' {
            Write-Log "Using custom DC list from file..." -Level OK
            if ([string]::IsNullOrWhiteSpace($CustomDCListPath)) {
                Write-Log "CustomDCListPath is required when ScanScope is CustomDCList" -Level ERROR
                throw "CustomDCListPath parameter is required"
            }
            
            if (-not (Test-Path $CustomDCListPath)) {
                Write-Log "Custom DC list file not found: $CustomDCListPath" -Level ERROR
                throw "File not found: $CustomDCListPath"
            }
            
            try {
                $dcNames = Get-Content $CustomDCListPath | Where-Object { $_ -and $_.Trim() -ne '' }
                Write-Log "Loaded $($dcNames.Count) DC names from file" -Level INFO
                
                foreach ($dcName in $dcNames) {
                    try {
                        $dc = Get-ADDomainController -Identity $dcName.Trim() -ErrorAction Stop
                        $dcs += $dc
                    }
                    catch {
                        $errMsg = $_.Exception.Message
                        Write-Log "Could not find DC in AD: $dcName - $errMsg" -Level WARN
                        $dcs += [pscustomobject]@{
                            Name = $dcName.Trim()
                            HostName = $dcName.Trim()
                            Domain = "Unknown"
                            Site = "Unknown"
                            IPv4Address = ""
                            IPv6Address = ""
                            OperatingSystem = "Unknown"
                            IsGlobalCatalog = $false
                            IsReadOnly = $false
                            Enabled = $true
                        }
                    }
                }
            }
            catch {
                $errMsg = $_.Exception.Message
                Write-Log "Failed to process custom DC list: $errMsg" -Level ERROR
                throw
            }
            break
        }
        
        default {
            Write-Log "Unknown scan scope: $Scope. Using Forest scope." -Level WARN
            $dcs = Get-TargetDomainControllers -Scope 'Forest'
        }
    }
    
    $dcs = $dcs | Sort-Object HostName -Unique
    Write-Log "Total unique DCs to scan: $($dcs.Count)" -Level OK
    return $dcs
}


# =============================================================================
# SECTION 3: IMPROVED SERVICE DETECTION
# =============================================================================

function Test-DCReachability {
    param(
        [string]$ComputerName,
        [int]$TimeoutMs = 3000
    )
    
    # Method 1: Test TCP port 445 (SMB)
    try {
        $tcpClient = New-Object System.Net.Sockets.TcpClient
        $asyncResult = $tcpClient.BeginConnect($ComputerName, 445, $null, $null)
        $wait = $asyncResult.AsyncWaitHandle.WaitOne($TimeoutMs)
        if ($wait) {
            $tcpClient.EndConnect($asyncResult)
            $tcpClient.Close()
            return $true
        }
        $tcpClient.Close()
    }
    catch { }
    
    # Method 2: Test TCP port 389 (LDAP)
    try {
        $tcpClient = New-Object System.Net.Sockets.TcpClient
        $asyncResult = $tcpClient.BeginConnect($ComputerName, 389, $null, $null)
        $wait = $asyncResult.AsyncWaitHandle.WaitOne($TimeoutMs)
        if ($wait) {
            $tcpClient.EndConnect($asyncResult)
            $tcpClient.Close()
            return $true
        }
        $tcpClient.Close()
    }
    catch { }
    
    # Method 3: ICMP ping
    try {
        $ping = Test-Connection -ComputerName $ComputerName -Count 1 -Quiet -ErrorAction Stop -TimeoutSeconds 5
        if ($ping) {
            return $true
        }
    }
    catch { }
    
    return $false
}

function Get-DCServicesViaCIM {
    param(
        [string]$ComputerName,
        [bool]$IsReachable
    )
    
    $services = @{ 
        NTDS = 'Unknown'
        Netlogon = 'Unknown'
        KDC = 'Unknown'
        DFSR = 'Unknown'
        DNS = 'Unknown'
    }
    
    if (-not $IsReachable) {
        return $services
    }
    
    $serviceNames = @{
        'NTDS' = 'NTDS'
        'Netlogon' = 'Netlogon'
        'KDC' = 'kdc'
        'DFSR' = 'DFSR'
        'DNS' = 'DNS'
    }
    
    $cimSession = $null
    try {
        $cimSession = New-CimSession -ComputerName $ComputerName -ErrorAction Stop -OperationTimeoutSec 10
        
        foreach ($svcName in $serviceNames.Keys) {
            try {
                $query = "SELECT Name, State FROM Win32_Service WHERE Name = '$($serviceNames[$svcName])'"
                $result = Get-CimInstance -CimSession $cimSession -Query $query -ErrorAction Stop
                if ($result -and $result.State) {
                    $services[$svcName] = $result.State
                }
            }
            catch { }
        }
    }
    catch {
        foreach ($svcName in $serviceNames.Keys) {
            try {
                $svc = Get-Service -ComputerName $ComputerName -Name $serviceNames[$svcName] -ErrorAction Stop
                $services[$svcName] = $svc.Status.ToString()
            }
            catch { }
        }
    }
    finally {
        if ($cimSession) {
            Remove-CimSession -CimSession $cimSession -ErrorAction SilentlyContinue
        }
    }
    
    return $services
}

function Check-DCHealthImproved {
    param(
        [string]$HostName,
        [string]$Domain,
        [string]$Site,
        [string]$IPv4,
        [int]$PortCheckTimeoutMs
    )
    
    $reachable = Test-DCReachability -ComputerName $HostName -TimeoutMs $PortCheckTimeoutMs
    $services = Get-DCServicesViaCIM -ComputerName $HostName -IsReachable $reachable
    
    $dcStatus = 'Red'
    
    if ($reachable) {
        if ($services['NTDS'] -eq 'Running' -and $services['Netlogon'] -eq 'Running') {
            $dcStatus = 'Green'
        }
        elseif ($services['NTDS'] -eq 'Running' -or $services['Netlogon'] -eq 'Running') {
            $dcStatus = 'Yellow'
        }
        else {
            $dcStatus = 'Yellow'
        }
    }
    
    return [pscustomobject]@{
        Domain      = $Domain
        HostName    = $HostName
        Site        = $Site
        IPv4Address = $IPv4
        Reachable   = $reachable
        NTDS        = $services['NTDS']
        Netlogon    = $services['Netlogon']
        KDC         = $services['KDC']
        DFSR        = $services['DFSR']
        DNS         = $services['DNS']
        DcStatus    = $dcStatus
    }
}

function Collect-DCHealth {
    param(
        [array]$DomainControllers,
        [int]$PortCheckTimeoutMs
    )
    
    Write-Log "Collecting health for $($DomainControllers.Count) domain controllers..." -Level OK
    
    $dcRows = @()
    $total = $DomainControllers.Count
    $current = 0
    
    foreach ($dc in $DomainControllers) {
        $current++
        Write-Log "Processing DC $current of $total : $($dc.HostName)" -Level INFO
        
        try {
            $result = Check-DCHealthImproved -HostName $dc.HostName -Domain $dc.Domain -Site $dc.Site -IPv4 $dc.IPv4Address -PortCheckTimeoutMs $PortCheckTimeoutMs
            $dcRows += $result
        }
        catch {
            $errMsg = $_.Exception.Message
            Write-Log "Failed to process DC $($dc.HostName): $errMsg" -Level ERROR
            $dcRows += [pscustomobject]@{
                Domain      = $dc.Domain
                HostName    = $dc.HostName
                Site        = $dc.Site
                IPv4Address = $dc.IPv4Address
                Reachable   = $false
                NTDS        = 'Error'
                Netlogon    = 'Error'
                KDC         = 'Error'
                DFSR        = 'Error'
                DNS         = 'Error'
                DcStatus    = 'Red'
            }
        }
    }
    
    $reachableCount = @($dcRows | Where-Object { $_.Reachable -eq $true }).Count
    Write-Log "Health collection complete. $reachableCount of $total DCs are reachable." -Level OK
    return $dcRows
}


# =============================================================================
# SECTION 4: EVENT LOG COLLECTION FUNCTIONS
# =============================================================================

function Get-UnexpectedShutdownEvents {
    param(
        [array]$DomainControllers,
        [datetime]$StartTime
    )
    
    $shutdownEvents = @()
    
    Write-Log "Collecting unexpected shutdown events..." -Level INFO
    
    foreach ($dc in $DomainControllers) {
        if (-not $dc.HostName) { continue }
        try {
            $filterHash = @{
                LogName = 'System'
                ID = 6008
                StartTime = $StartTime
            }
            $events = Get-WinEvent -ComputerName $dc.HostName -FilterHashtable $filterHash -MaxEvents 100 -ErrorAction SilentlyContinue
            
            foreach ($evt in $events) {
                $shutdownEvents += [pscustomobject]@{
                    SourceDC = $dc.HostName
                    TimeCreated = $evt.TimeCreated
                    EventID = $evt.Id
                    EventName = 'Unexpected Shutdown'
                    Severity = 'Critical'
                    Message = ($evt.Message -replace "`r`n", ' ' -replace "`n", ' ') | Select-Object -First 300
                }
            }
        }
        catch { }
    }
    
    Write-Log "Found $($shutdownEvents.Count) unexpected shutdown events" -Level INFO
    return $shutdownEvents
}

function Get-EventsFromDC {
    param(
        [string]$ComputerName,
        [datetime]$StartTime
    )
    
    $events = @()
    
    $eventDetails = @{
        '4625' = @{ Name = 'Failed Logon'; Severity = 'Warning'; LogName = 'Security'; Description = 'Wrong password or password spraying attack' }
        '4719' = @{ Name = 'Audit Policy Modified'; Severity = 'Critical'; LogName = 'Security'; Description = 'Security auditing settings were modified' }
        '4672' = @{ Name = 'Special Privileges Assigned'; Severity = 'Warning'; LogName = 'Security'; Description = 'Admin privileges assigned' }
        '4648' = @{ Name = 'Explicit Credential Logon'; Severity = 'Warning'; LogName = 'Security'; Description = 'Logon using explicit credentials' }
        '1100' = @{ Name = 'Event Log Shutdown'; Severity = 'Warning'; LogName = 'System'; Description = 'Event logging service shut down' }
        '1074' = @{ Name = 'Planned Restart'; Severity = 'Info'; LogName = 'System'; Description = 'Planned restart or shutdown' }
    }
    
    $securityEventIds = @('4625', '4719', '4672', '4648')
    foreach ($eventId in $securityEventIds) {
        try {
            $filterHash = @{
                LogName = 'Security'
                ID = $eventId
                StartTime = $StartTime
            }
            $results = Get-WinEvent -ComputerName $ComputerName -FilterHashtable $filterHash -MaxEvents 50 -ErrorAction SilentlyContinue
            foreach ($evt in $results) {
                $details = $eventDetails[$eventId]
                $events += [pscustomobject]@{
                    SourceDC = $ComputerName
                    TimeCreated = $evt.TimeCreated
                    LogName = $details.LogName
                    EventID = $evt.Id
                    EventName = $details.Name
                    Severity = $details.Severity
                    Description = $details.Description
                    Message = ($evt.Message -replace "`r`n", ' ' -replace "`n", ' ') | Select-Object -First 300
                }
            }
        }
        catch { }
    }
    
    $systemEventIds = @('1100', '1074')
    foreach ($eventId in $systemEventIds) {
        try {
            $filterHash = @{
                LogName = 'System'
                ID = $eventId
                StartTime = $StartTime
            }
            $results = Get-WinEvent -ComputerName $ComputerName -FilterHashtable $filterHash -MaxEvents 50 -ErrorAction SilentlyContinue
            foreach ($evt in $results) {
                $details = $eventDetails[$eventId]
                $events += [pscustomobject]@{
                    SourceDC = $ComputerName
                    TimeCreated = $evt.TimeCreated
                    LogName = $details.LogName
                    EventID = $evt.Id
                    EventName = $details.Name
                    Severity = $details.Severity
                    Description = $details.Description
                    Message = ($evt.Message -replace "`r`n", ' ' -replace "`n", ' ') | Select-Object -First 300
                }
            }
        }
        catch { }
    }
    
    return $events
}

function Collect-AllEvents {
    param(
        [array]$DomainControllers,
        [datetime]$StartTime
    )
    
    $allEvents = @()
    
    Write-Log "Collecting event logs from $($DomainControllers.Count) domain controllers..." -Level OK
    
    $total = $DomainControllers.Count
    $current = 0
    
    foreach ($dc in $DomainControllers) {
        if (-not $dc.HostName) { continue }
        $current++
        Write-Log "Processing events from DC $current of $total : $($dc.HostName)" -Level INFO
        
        try {
            $events = Get-EventsFromDC -ComputerName $dc.HostName -StartTime $StartTime
            foreach ($event in $events) {
                $allEvents += $event
            }
        }
        catch {
            $errMsg = $_.Exception.Message
            Write-Log "Failed to collect events from $($dc.HostName): $errMsg" -Level WARN
        }
    }
    
    Write-Log "Event collection complete. Total events: $($allEvents.Count)" -Level OK
    return $allEvents
}


# =============================================================================
# SECTION 5: AD STRUCTURE FUNCTIONS
# =============================================================================

function Get-FSMORoleStatus {
    param($Domain, $Forest)
    
    $fsmoRows = @()
    
    try {
        $holder = $Domain.PDCEmulator
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 3000
        $fsmoRows += [pscustomobject]@{ Role = 'PDC Emulator'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'PDC Emulator'; Holder = 'Unknown'; Reachable = $false }
    }
    
    try {
        $holder = $Domain.RIDMaster
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 3000
        $fsmoRows += [pscustomobject]@{ Role = 'RID Master'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'RID Master'; Holder = 'Unknown'; Reachable = $false }
    }
    
    try {
        $holder = $Domain.InfrastructureMaster
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 3000
        $fsmoRows += [pscustomobject]@{ Role = 'Infrastructure Master'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'Infrastructure Master'; Holder = 'Unknown'; Reachable = $false }
    }
    
    try {
        $holder = $Forest.SchemaMaster
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 3000
        $fsmoRows += [pscustomobject]@{ Role = 'Schema Master'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'Schema Master'; Holder = 'Unknown'; Reachable = $false }
    }
    
    try {
        $holder = $Forest.DomainNamingMaster
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 3000
        $fsmoRows += [pscustomobject]@{ Role = 'Domain Naming Master'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'Domain Naming Master'; Holder = 'Unknown'; Reachable = $false }
    }
    
    return $fsmoRows
}

function Get-ReplicationFailures {
    $replFailureRows = @()
    try {
        $replFailures = @(Get-ADReplicationFailure -Scope Forest -ErrorAction Stop)
        foreach ($f in $replFailures) {
            $replFailureRows += [pscustomobject]@{
                Server = [string]$f.Server
                Partner = [string]$f.Partner
                LastError = [string]$f.LastError
                FailureCount = [int]$f.FailureCount
                FirstFailureTime = $f.FirstFailureTime
                LastFailureTime = $f.LastFailureTime
            }
        }
    }
    catch {
        $errMsg = $_.Exception.Message
        Write-Log "Get-ADReplicationFailure failed: $errMsg" -Level WARN
    }
    
    return $replFailureRows
}

function Get-ReplicationSummaryText {
    $replText = ''
    if ($IncludeReplicationText -and (Get-Command repadmin.exe -ErrorAction SilentlyContinue)) {
        try {
            $replText = & repadmin.exe /replsummary 2>&1 | Out-String
            if ([string]::IsNullOrWhiteSpace($replText)) {
                $replText = 'No replication issues detected.'
            }
        }
        catch {
            $errMsg = $_.Exception.Message
            $replText = "repadmin failed: $errMsg"
        }
    }
    elseif (-not $IncludeReplicationText) {
        $replText = 'Replication summary skipped'
    }
    else {
        $replText = 'repadmin.exe not found in PATH'
    }
    
    return $replText
}

function Get-SiteStatistics {
    param([array]$DcRows)
    
    $siteStats = @()
    $siteGroups = $DcRows | Group-Object -Property Site
    
    foreach ($group in $siteGroups) {
        $sg = @($group.Group)
        $sRed = @($sg | Where-Object { $_.DcStatus -eq 'Red' }).Count
        $sYel = @($sg | Where-Object { $_.DcStatus -eq 'Yellow' }).Count
        $sGrn = @($sg | Where-Object { $_.DcStatus -eq 'Green' }).Count
        $sColor = if ($sRed -gt 0) { 'red' } elseif ($sYel -gt 0) { 'yellow' } else { 'green' }
        
        $siteStats += [pscustomobject]@{
            Site = if ([string]::IsNullOrWhiteSpace($group.Name)) { 'Unknown' } else { [string]$group.Name }
            Total = $sg.Count
            Red = $sRed
            Yellow = $sYel
            Green = $sGrn
            Color = $sColor
        }
    }
    
    $siteStats = $siteStats | Sort-Object Color, Site
    return $siteStats
}


# =============================================================================
# SECTION 6: HTML GENERATION FUNCTIONS
# =============================================================================

function Build-SiteCardsHtml {
    param([array]$SiteStats)
    
    $html = @()
    foreach ($stat in $SiteStats) {
        $statusLine = if ($stat.Red -gt 0) { "$($stat.Red) unreachable" }
                      elseif ($stat.Yellow -gt 0) { "$($stat.Yellow) service issue" }
                      else { 'All healthy' }
        $dcText = if ($stat.Total -eq 1) { '1 DC' } else { "$($stat.Total) DCs" }
        
        $html += "<div class='site-card site-$($stat.Color)'>" +
                 "<div class='site-name'>$(HtmlSafe $stat.Site)</div>" +
                 "<div class='site-count'>$dcText</div>" +
                 "<div class='site-status'>$statusLine</div>" +
                 "</div>"
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-PriorityIssuesHtml {
    param([array]$DcRows)
    
    $issueRows = @($DcRows | Where-Object { $_.DcStatus -ne 'Green' })
    
    if ($issueRows.Count -eq 0) {
        return "<tr><td colspan='9' style='text-align:center'>No issues detected in this run</td></tr>"
    }
    
    $html = @()
    foreach ($dc in ($issueRows | Sort-Object DcStatus, Site, HostName)) {
        $rc = if ($dc.DcStatus -eq 'Red') { 'row-red' } else { 'row-yellow' }
        $html += "<tr class='$rc'>" +
                 "<td>$(HtmlSafe $dc.Site)</td>" +
                 "<td>$(HtmlSafe $dc.HostName)</td>" +
                 "<td>$(HtmlSafe $dc.IPv4Address)</td>" +
                 "<td>$(HtmlSafe $dc.Reachable)</td>" +
                 "<td>$(Get-SvcBadge $dc.NTDS)</td>" +
                 "<td>$(Get-SvcBadge $dc.Netlogon)</td>" +
                 "<td>$(Get-SvcBadge $dc.KDC)</td>" +
                 "<td>$(Get-SvcBadge $dc.DFSR)</td>" +
                 "<td>$(Get-SvcBadge $dc.DNS)</td>" +
                 "</tr>"
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-FSMOHtml {
    param([array]$FsmoRows)
    
    $html = @()
    foreach ($fsmo in $FsmoRows) {
        $rc = if (-not $fsmo.Reachable) { 'row-red' } else { '' }
        $icon = if ($fsmo.Reachable) { "<span class='svc svc-ok'>Reachable</span>" } 
                else { "<span class='svc svc-bad'>UNREACHABLE</span>" }
        $html += "<tr class='$rc'>" +
                 "<td>$(HtmlSafe $fsmo.Role)</td>" +
                 "<td>$(HtmlSafe $fsmo.Holder)</td>" +
                 "<td>$icon</td>" +
                 "</tr>"
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-ReplicationFailHtml {
    param([array]$ReplFailureRows)
    
    if ($ReplFailureRows.Count -eq 0) {
        return "<tr><td colspan='6'>No replication failures detected across the forest.</td></tr>"
    }
    
    $html = @()
    foreach ($r in ($ReplFailureRows | Sort-Object FailureCount -Descending)) {
        $html += "<tr class='row-yellow'>" +
                 "<td>$(HtmlSafe $r.Server)</td>" +
                 "<td>$(HtmlSafe $r.Partner)</td>" +
                 "<td>$(HtmlSafe $r.LastError)</td>" +
                 "<td>$(HtmlSafe $r.FailureCount)</td>" +
                 "<td>$(HtmlSafe $r.FirstFailureTime)</td>" +
                 "<td>$(HtmlSafe $r.LastFailureTime)</td>" +
                 "</tr>"
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-DCSiteSectionsHtml {
    param([array]$DcRows)
    
    $html = @()
    $siteGroups = $DcRows | Group-Object -Property Site | Sort-Object Name
    
    foreach ($group in $siteGroups) {
        $siteName = if ([string]::IsNullOrWhiteSpace($group.Name)) { 'Unknown' } else { [string]$group.Name }
        $safeId = $siteName -replace '[^a-zA-Z0-9]', '_'
        $siteDcs = @($group.Group | Sort-Object DcStatus, HostName)
        $sRed = @($siteDcs | Where-Object { $_.DcStatus -eq 'Red' }).Count
        $sYel = @($siteDcs | Where-Object { $_.DcStatus -eq 'Yellow' }).Count
        $badgeColor = if ($sRed -gt 0) { 'red' } elseif ($sYel -gt 0) { 'yellow' } else { 'green' }
        $badgeLabel = if ($sRed -gt 0) { "Red ($sRed unreachable)" } 
                      elseif ($sYel -gt 0) { "Yellow ($sYel issue)" } 
                      else { 'Green' }
        $dcCountText = if ($siteDcs.Count -eq 1) { '1 DC' } else { "$($siteDcs.Count) DCs" }
        
        $rows = @()
        foreach ($dc in $siteDcs) {
            $rc = switch ($dc.DcStatus) { 
                'Red' { 'dc-row row-red' } 
                'Yellow' { 'dc-row row-yellow' } 
                default { 'dc-row' } 
            }
            $reachIcon = if ($dc.Reachable) { "<span class='svc svc-ok'>Yes</span>" } 
                         else { "<span class='svc svc-bad'>No</span>" }
            $search = ($dc.HostName + ' ' + $dc.IPv4Address + ' ' + $dc.Site).ToLower()
            
            $rows += "<tr class='$rc' data-search='$(HtmlSafe $search)'>" +
                     "<td>$(HtmlSafe $dc.HostName)</td>" +
                     "<td>$(HtmlSafe $dc.IPv4Address)</td>" +
                     "<td>$reachIcon</td>" +
                     "<td>$(Get-SvcBadge $dc.NTDS)</td>" +
                     "<td>$(Get-SvcBadge $dc.Netlogon)</td>" +
                     "<td>$(Get-SvcBadge $dc.KDC)</td>" +
                     "<td>$(Get-SvcBadge $dc.DFSR)</td>" +
                     "<td>$(Get-SvcBadge $dc.DNS)</td>" +
                     "</tr>"
        }
        
        $block = "<div class='site-section'>"
        $block += "<div class='site-header' onclick='toggleSite(`"$safeId`")'>"
        $block += "<span class='badge badge-$badgeColor'>$badgeLabel</span>"
        $block += "<strong>$(HtmlSafe $siteName)</strong>"
        $block += "<span class='dc-count'>$dcCountText</span>"
        $block += "<span class='toggle-hint'>(click to expand)</span></div>"
        $block += "<div id='site-$safeId' class='site-table' style='display:none'>"
        $block += "<table><thead>"
        $block += "<tr><th>Domain Controller</th><th>IP Address</th><th>Reachable</th>"
        $block += "<th>NTDS</th><th>Netlogon</th><th>KDC</th><th>DFSR</th><th>DNS</th></tr>"
        $block += "</thead><tbody>" + ($rows -join [Environment]::NewLine) + "</tbody></table>"
        $block += "</div></div>"
        
        $html += $block
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-EventsHtml {
    param([array]$Events)
    
    if ($Events.Count -eq 0) {
        return "<div class='no-events'>No events detected in the last $EventLookbackHours hour(s).</div>"
    }
    
    $severityOrder = @{ 'Critical' = 1; 'Warning' = 2; 'Info' = 3 }
    $sortedEvents = $Events | Sort-Object { $severityOrder[[string]$_.Severity] }, TimeCreated -Descending
    
    $html = "<thead>"
    $html += "<tr><th>Time</th><th>Source DC</th><th>Event ID</th><th>Event Name</th><th>Severity</th><th>Description</th><th>Message</th></tr>"
    $html += "</thead><tbody>"
    
    $count = 0
    foreach ($event in $sortedEvents) {
        if ($count -ge 200) { 
            $html += "<tr><td colspan='7' class='text-center'>... and $($Events.Count - 200) more events (see CSV export for full list) nonexistent nonexistent"
            break 
        }
        
        $severityClass = switch ($event.Severity) {
            'Critical' { 'event-critical' }
            'Warning'  { 'event-warning' }
            default    { 'event-info' }
        }
        
        $shortMessage = $event.Message
        if ($shortMessage.Length -gt 200) {
            $shortMessage = $shortMessage.Substring(0, 200) + "..."
        }
        
        $html += "<tr class='$severityClass'>"
        $html += "<td>$($event.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))</td>"
        $html += "<td>$(HtmlSafe $event.SourceDC)</td>"
        $html += "<td>$($event.EventID)</td>"
        $html += "<td>$(HtmlSafe $event.EventName)</td>"
        $html += "<td><span class='event-badge $severityClass'>$(HtmlSafe $event.Severity)</span></td>"
        $html += "<td><div class='event-message'>$(HtmlSafe $event.Description)</div></td>"
        $html += "<td><div class='event-message'>$(HtmlSafe $shortMessage)</div></td>"
        $html += "</tr>"
        $count++
    }
    
    $html += "</tbody>"
    return $html
}

function Build-ShutdownEventsHtml {
    param([array]$ShutdownEvents)
    
    if ($ShutdownEvents.Count -eq 0) {
        return "<div class='no-events'>No unexpected shutdown events (Event ID 6008) detected in the last $EventLookbackHours hour(s).</div>"
    }
    
    $sortedEvents = $ShutdownEvents | Sort-Object TimeCreated -Descending
    
    $html = "<thead>"
    $html += "<tr><th>Time</th><th>Source DC</th><th>Event ID</th><th>Event Name</th><th>Severity</th><th>Message</th></tr>"
    $html += "</thead><tbody>"
    
    $count = 0
    foreach ($event in $sortedEvents) {
        if ($count -ge 100) { 
            $html += "<tr><td colspan='6' class='text-center'>... and $($ShutdownEvents.Count - 100) more events (see CSV export for full list) nonexistent nonexistent"
            break 
        }
        
        $shortMessage = $event.Message
        if ($shortMessage.Length -gt 300) {
            $shortMessage = $shortMessage.Substring(0, 300) + "..."
        }
        
        $html += "<tr class='event-critical'>"
        $html += "<td>$($event.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))</td>"
        $html += "<td>$(HtmlSafe $event.SourceDC)</td>"
        $html += "<td>$($event.EventID)</td>"
        $html += "<td>$(HtmlSafe $event.EventName)</td>"
        $html += "<td><span class='event-badge event-critical'>Critical</span></td>"
        $html += "<td><div class='event-message'>$(HtmlSafe $shortMessage)</div></td>"
        $html += "</tr>"
        $count++
    }
    
    $html += "</tbody>"
    return $html
}

function Build-EventStatsCards {
    param([array]$Events)
    
    $criticalCount = @($Events | Where-Object { $_.Severity -eq 'Critical' }).Count
    $warningCount = @($Events | Where-Object { $_.Severity -eq 'Warning' }).Count
    $infoCount = @($Events | Where-Object { $_.Severity -eq 'Info' }).Count
    
    $totalEvents = $Events.Count    
    $failedLogonCount = @($Events | Where-Object { $_.EventID -eq '4625' }).Count
    $auditChangeCount = @($Events | Where-Object { $_.EventID -eq '4719' }).Count
    $adminLoginCount = @($Events | Where-Object { $_.EventID -eq '4672' }).Count
    $explicitCredCount = @($Events | Where-Object { $_.EventID -eq '4648' }).Count
    
    $html = "<div class='cards'>"
    $html += "<div class='card'><div class='k'>Total Events</div><div class='v'>$totalEvents</div></div>"
    $html += "<div class='card event-critical'><div class='k'>Critical</div><div class='v'>$criticalCount</div></div>"
    $html += "<div class='card event-warning'><div class='k'>Warning</div><div class='v'>$warningCount</div></div>"
    $html += "<div class='card event-info'><div class='k'>Informational</div><div class='v'>$infoCount</div></div>"
    $html += "</div>"
    
    $html += "<div class='cards' style='margin-top: 10px;'>"
    $html += "<div class='card'><div class='k'>Failed Logons (4625)</div><div class='v'>$failedLogonCount</div></div>"
    $html += "<div class='card'><div class='k'>Audit Changes (4719)</div><div class='v'>$auditChangeCount</div></div>"
    $html += "<div class='card'><div class='k'>Admin Logins (4672)</div><div class='v'>$adminLoginCount</div></div>"
    $html += "<div class='card'><div class='k'>Explicit Cred (4648)</div><div class='v'>$explicitCredCount</div></div>"
    $html += "</div>"
    
    return $html
}

function Build-ShutdownStatsCards {
    param([array]$ShutdownEvents)
    
    $shutdownCount = $ShutdownEvents.Count
    $uniqueDcs = $ShutdownEvents | Select-Object -Property SourceDC -Unique
    $affectedDcCount = $uniqueDcs.Count
    
    $html = "<div class='cards'>"
    $html += "<div class='card event-critical'><div class='k'>Unexpected Shutdowns</div><div class='v'>$shutdownCount</div></div>"
    $html += "<div class='card event-warning'><div class='k'>Affected DCs</div><div class='v'>$affectedDcCount</div></div>"
    $html += "</div>"
    
    return $html
}


# =============================================================================
# SECTION 7: MAIN EXECUTION
# =============================================================================

try {
    if ($Runbook) {
        Write-HealthRunbook
        return
    }
    
    if (-not (Test-Path -LiteralPath $OutputDirectory)) {
        New-Item -ItemType Directory -Path $OutputDirectory -Force | Out-Null
        Write-Log "Created output directory: $OutputDirectory" -Level OK
    }
    
    Write-Log "==========================================================================" -Level OK
    Write-Log "              AD Daily Health Summary - Starting Collection" -Level OK
    Write-Log "==========================================================================" -Level OK
    Write-Log "Scan Scope: $ScanScope" -Level OK
    if ($ScanScope -eq 'CustomDCList') {
        Write-Log "Custom DC List Path: $CustomDCListPath" -Level INFO
    }
    
    Write-Log "Loading ActiveDirectory module..." -Level INFO
    Import-Module ActiveDirectory -ErrorAction Stop
    Write-Log "ActiveDirectory module loaded successfully." -Level OK
    
    $allDcs = Get-TargetDomainControllers -Scope $ScanScope -CustomDCListPath $CustomDCListPath
    
    if ($DemoMode -and $allDcs.Count -gt $DemoDomainControllerLimit) {
        $allDcs = @($allDcs | Select-Object -First $DemoDomainControllerLimit)
        Write-Log "Demo mode: limited to first $DemoDomainControllerLimit domain controllers." -Level WARN
    }
    
    $domain = Get-ADDomain
    $forest = Get-ADForest
    
    Write-Log "Domain: $($domain.DNSRoot)" -Level INFO
    Write-Log "Forest: $($forest.Name)" -Level INFO
    Write-Log "Total Domain Controllers to scan: $($allDcs.Count)" -Level INFO
    
    $dcRows = Collect-DCHealth -DomainControllers $allDcs -PortCheckTimeoutMs $PortCheckTimeoutMs
    
    Write-Log "Collecting FSMO role status..." -Level INFO
    $fsmoRows = Get-FSMORoleStatus -Domain $domain -Forest $forest
    
    Write-Log "Collecting replication failures..." -Level INFO
    $replFailureRows = Get-ReplicationFailures
    
    Write-Log "Getting replication summary..." -Level INFO
    $replText = Get-ReplicationSummaryText
    
    Write-Log "Calculating site statistics..." -Level INFO
    $siteStats = Get-SiteStatistics -DcRows $dcRows
    
    $allEvents = @()
    $shutdownEvents = @()
    
    if (-not $SkipEventLogs) {
        $startTime = (Get-Date).AddHours(-$EventLookbackHours)
        Write-Log "Collecting events from last $EventLookbackHours hour(s)..." -Level INFO
        
        $shutdownEvents = Get-UnexpectedShutdownEvents -DomainControllers $allDcs -StartTime $startTime
        $allEvents = Collect-AllEvents -DomainControllers $allDcs -StartTime $startTime
    } else {
        Write-Log "Event collection skipped (SkipEventLogs = true)" -Level WARN
    }
    
    $reachableCount = @($dcRows | Where-Object { $_.Reachable -eq $true }).Count
    $unreachableCount = @($dcRows | Where-Object { $_.Reachable -eq $false }).Count
    $issueRows = @($dcRows | Where-Object { $_.DcStatus -ne 'Green' })
    $fsmoDown = @($fsmoRows | Where-Object { -not $_.Reachable }).Count
    $replIssueCount = $replFailureRows.Count
    
    $healthStatus = if ($unreachableCount -gt 0 -or $fsmoDown -gt 0) { 'Red' }
                    elseif ($issueRows.Count -gt 0 -or $replIssueCount -gt 0) { 'Yellow' }
                    else { 'Green' }
    
    $escalationGuidance = switch ($healthStatus) {
        'Red'    { 'WARNING: One or more domain controllers or FSMO role holders are unreachable. Investigate immediately.' }
        'Yellow' { 'ATTENTION: Service degradation or replication failures detected. Review the issues below.' }
        default  { 'All domain controllers and FSMO role holders are healthy. Continue daily monitoring.' }
    }
    
    $scopeDescription = switch ($ScanScope) {
        'CurrentDomain' { "Current Domain: $($domain.DNSRoot)" }
        'CustomDCList' { "Custom DC List ($($allDcs.Count) DCs from file)" }
        default { "Full Forest: $($forest.Name) ($($allDcs.Count) DCs)" }
    }
    
    Write-Log "Building HTML report..." -Level INFO
    $siteCardsHtml = Build-SiteCardsHtml -SiteStats $siteStats
    $priorityHtml = Build-PriorityIssuesHtml -DcRows $dcRows
    $fsmoHtml = Build-FSMOHtml -FsmoRows $fsmoRows
    $replFailHtml = Build-ReplicationFailHtml -ReplFailureRows $replFailureRows
    $siteGroupHtml = Build-DCSiteSectionsHtml -DcRows $dcRows
    $eventStatsHtml = Build-EventStatsCards -Events $allEvents
    $eventsHtml = Build-EventsHtml -Events $allEvents
    $shutdownStatsHtml = Build-ShutdownStatsCards -ShutdownEvents $shutdownEvents
    $shutdownEventsHtml = Build-ShutdownEventsHtml -ShutdownEvents $shutdownEvents
    
    $stamp = Get-Date -Format 'yyyyMMdd_HHmmss'
    $htmlPath = Join-Path $OutputDirectory "AD_Daily_Health_Summary_$stamp.html"
    $dcCsv = Join-Path $OutputDirectory "AD_Daily_Health_DCs_$stamp.csv"
    $eventCsv = Join-Path $OutputDirectory "AD_Daily_Health_Events_$stamp.csv"
    $shutdownCsv = Join-Path $OutputDirectory "AD_Daily_Health_Shutdowns_$stamp.csv"
    $jsonPath = Join-Path $OutputDirectory "AD_Daily_Health_Summary_$stamp.json"
    
    Write-Log "Exporting CSV files..." -Level INFO
    $dcRows | Export-Csv -Path $dcCsv -NoTypeInformation -Encoding UTF8
    $allEvents | Export-Csv -Path $eventCsv -NoTypeInformation -Encoding UTF8
    $shutdownEvents | Export-Csv -Path $shutdownCsv -NoTypeInformation -Encoding UTF8
    Write-Log "Exported DC CSV: $dcCsv" -Level OK
    Write-Log "Exported Events CSV: $eventCsv" -Level OK
    Write-Log "Exported Shutdown Events CSV: $shutdownCsv" -Level OK
    
    $htmlContent = @"
<!DOCTYPE html>
<html lang='en'>
<head>
<meta charset='UTF-8'>
<title>AD Daily Health Summary</title>
<style>
:root{--bg1:#eaf3ff;--bg2:#dbeafe;--panel:#fff;--border:#bfd6f6;--title:#0f2a56;--text:#16335f;--muted:#47678f;--head:#e1eeff;--green:#22c55e;--green-bg:#f0fdf4;--yellow:#f59e0b;--yellow-bg:#fffbeb;--red:#ef4444;--red-bg:#fef2f2;--blue:#3b82f6;--blue-bg:#eff6ff}
*{box-sizing:border-box}
body{font-family:Segoe UI,Arial,sans-serif;margin:0;padding:16px;background:linear-gradient(160deg,var(--bg1),var(--bg2));color:var(--text)}
h1,h2{margin:0 0 8px 0;color:var(--title)}
.panel{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:14px}
.meta{color:var(--muted);font-size:13px}
.cards{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px}
.card{background:linear-gradient(180deg,#fff,var(--bg1));border:1px solid var(--border);border-radius:12px;padding:10px 16px;min-width:130px}
.k{font-size:11px;text-transform:uppercase;color:var(--muted)}
.v{font-size:26px;font-weight:700;color:var(--title)}
.badge{display:inline-block;padding:3px 10px;border-radius:999px;font-weight:600;font-size:12px}
.badge-green{background:var(--green-bg);color:#166534}
.badge-yellow{background:var(--yellow-bg);color:#92400e}
.badge-red{background:var(--red-bg);color:#991b1b}
.esc{padding:10px 14px;border-radius:8px;font-weight:500}
.esc-green{background:var(--green-bg);border-left:4px solid var(--green)}
.esc-yellow{background:var(--yellow-bg);border-left:4px solid var(--yellow)}
.esc-red{background:var(--red-bg);border-left:4px solid var(--red)}
.site-grid{display:flex;gap:10px;flex-wrap:wrap}
.site-card{border-radius:10px;padding:10px 14px;min-width:155px}
.site-green{background:var(--green-bg);border:1px solid #86efac}
.site-yellow{background:var(--yellow-bg);border:1px solid #fcd34d}
.site-red{background:var(--red-bg);border:1px solid #fca5a5}
.site-name{font-weight:600}
.site-section{margin-bottom:6px;border:1px solid var(--border);border-radius:10px;overflow:hidden}
.site-header{background:var(--head);padding:9px 14px;cursor:pointer;display:flex;align-items:center;gap:10px}
.site-header:hover{background:#cde5ff}
.toggle-hint{margin-left:auto;font-size:11px;color:var(--muted)}
table{border-collapse:collapse;width:100%;font-size:12px;background:#fff}
th,td{border:1px solid #d4e4fb;padding:6px 8px;text-align:left}
th{background:var(--head);color:var(--title)}
.row-red td{background:var(--red-bg)}
.row-yellow td{background:var(--yellow-bg)}
.svc{display:inline-block;padding:2px 7px;border-radius:4px;font-size:11px;font-weight:500}
.svc-ok{background:var(--green-bg);color:#166534}
.svc-bad{background:var(--red-bg);color:#991b1b}
.svc-unk{background:#f1f5f9;color:#64748b}
.event-badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600}
.event-critical{background:var(--red-bg);color:#991b1b}
.event-warning{background:var(--yellow-bg);color:#92400e}
.event-info{background:var(--blue-bg);color:#1e40af}
.event-message{max-width:500px;word-break:break-word;font-size:11px}
.no-events{padding:20px;text-align:center;color:var(--muted)}
.search-bar{width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:8px;margin-bottom:10px}
pre{background:#0f172a;color:#e2e8f0;padding:12px;border-radius:8px;overflow-x:auto;font-size:12px}
.tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;border-bottom:2px solid var(--border);padding-bottom:10px}
.tab-btn{background:var(--panel);border:1px solid var(--border);padding:10px 20px;border-radius:8px;cursor:pointer;font-weight:600;transition:all 0.3s}
.tab-btn:hover{background:var(--head)}
.tab-btn.active{background:linear-gradient(135deg,var(--blue),#2563eb);color:white}
.tab-content{display:none}
.tab-content.active{display:block}
</style>
</head>
<body>
<div class='panel'>
<h1>AD Active Directory Daily Health Summary</h1>
<div class='meta'>Generated: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')</div>
<div class='meta'>Domain: $(HtmlSafe $domain.DNSRoot) | Forest: $(HtmlSafe $forest.Name)</div>
<div class='meta'>Scan Scope: $(HtmlSafe $scopeDescription) | DCs: $($dcRows.Count) | Sites: $($siteStats.Count)</div>
<div class='meta'>Event Lookback: $EventLookbackHours hours</div>
</div>

<div class='cards'>
<div class='card'><div class='k'>Overall Health</div><div class='v'><span class='badge badge-$($healthStatus.ToLowerInvariant())'>$healthStatus</span></div></div>
<div class='card'><div class='k'>Domain Controllers</div><div class='v'>$($dcRows.Count)</div></div>
<div class='card'><div class='k'>Reachable</div><div class='v'>$reachableCount</div></div>
<div class='card'><div class='k'>Unreachable</div><div class='v'>$unreachableCount</div></div>
<div class='card'><div class='k'>Service Issues</div><div class='v'>$($issueRows.Count)</div></div>
<div class='card'><div class='k'>Replication Issues</div><div class='v'>$replIssueCount</div></div>
<div class='card'><div class='k'>FSMO Issues</div><div class='v'>$fsmoDown</div></div>
</div>

<div class='panel'><div class='esc esc-$($healthStatus.ToLowerInvariant())'>$escalationGuidance</div></div>

<div class='tabs'>
<button class='tab-btn active' onclick='showTab("overview")'>Overview</button>
<button class='tab-btn' onclick='showTab("sites")'>Sites and DCs</button>
<button class='tab-btn' onclick='showTab("security")'>Security Events</button>
<button class='tab-btn' onclick='showTab("shutdown")'>Unexpected Shutdowns</button>
<button class='tab-btn' onclick='showTab("replication")'>Replication</button>
<button class='tab-btn' onclick='showTab("fsmo")'>FSMO Roles</button>
</div>

<div id='tab-overview' class='tab-content active'>
<div class='panel'><h2>Site Health Overview</h2><div class='site-grid'>$siteCardsHtml</div></div>
<div class='panel'><h2>Priority Issues</h2><div class='table-wrapper'><table><thead><th>Site</th><th>Domain Controller</th><th>IP</th><th>Reachable</th><th>NTDS</th><th>Netlogon</th><th>KDC</th><th>DFSR</th><th>DNS</th></thead><tbody>$priorityHtml</tbody></table></div></div>
</div>

<div id='tab-sites' class='tab-content'>
<div class='panel'><h2>All Domain Controllers by Site</h2><input class='search-bar' type='text' id='dcSearch' placeholder='Search by DC name or IP...' oninput='filterDCs(this.value)'>$siteGroupHtml</div>
</div>

<div id='tab-security' class='tab-content'>
<div class='panel'><h2>Security Events (Last $EventLookbackHours Hours)</h2>$eventStatsHtml<div class='table-wrapper' style='max-height:500px;overflow-y:auto'><table>$eventsHtml</table></div><div class='meta'>Full list: $(Split-Path $eventCsv -Leaf)</div></div>
</div>

<div id='tab-shutdown' class='tab-content'>
<div class='panel'><h2>Unexpected Shutdown Events - Event ID 6008</h2>$shutdownStatsHtml<div class='table-wrapper' style='max-height:500px;overflow-y:auto'><table>$shutdownEventsHtml</table></div><div class='meta'>Full list: $(Split-Path $shutdownCsv -Leaf)</div></div>
</div>

<div id='tab-replication' class='tab-content'>
<div class='panel'><h2>Replication Failures</h2><div class='table-wrapper'><tr><thead><th>Server</th><th>Partner</th><th>Last Error</th><th>Failure Count</th><th>First Failure</th><th>Last Failure</th></thead><tbody>$replFailHtml</tbody></table></div></div>
<div class='panel'><h2>Replication Summary (repadmin)</h2><pre>$(HtmlSafe $replText)</pre></div>
</div>

<div id='tab-fsmo' class='tab-content'>
<div class='panel'><h2>FSMO Role Holders</h2><div class='table-wrapper'></table><thead><th>Role</th><th>Holder</th><th>Status</th></thead><tbody>$fsmoHtml</tbody></table></div></div>
</div>

<div class='panel'><div class='meta' style='text-align:center'>
<strong>Output Files</strong><br/>
HTML: $(Split-Path $htmlPath -Leaf)<br/>
DC CSV: $(Split-Path $dcCsv -Leaf)<br/>
Events CSV: $(Split-Path $eventCsv -Leaf)<br/>
Shutdowns CSV: $(Split-Path $shutdownCsv -Leaf)
</div></div>

<script>
function showTab(tabName){
    document.querySelectorAll('.tab-content').forEach(function(t){t.classList.remove('active');});
    document.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active');});
    document.getElementById('tab-'+tabName).classList.add('active');
    event.target.classList.add('active');
}
function toggleSite(id){
    var el=document.getElementById('site-'+id);
    if(el){el.style.display=el.style.display==='none'?'':'none';}
}
function filterDCs(val){
    var lower=val.toLowerCase();
    document.querySelectorAll('.dc-row').forEach(function(r){
        var sd=r.getAttribute('data-search')||'';
        r.style.display=lower===''?'':(sd.indexOf(lower)>-1?'':'none');
    });
}
</script>
</body>
</html>
"@

    [System.IO.File]::WriteAllText($htmlPath, $htmlContent, [System.Text.Encoding]::UTF8)
    
    $jsonPayload = [pscustomobject]@{
        GeneratedOn = (Get-Date).ToString('s')
        ScanScope = $ScanScope
        Domain = [string]$domain.DNSRoot
        Forest = [string]$forest.Name
        HealthStatus = $healthStatus
        EventLookbackHours = $EventLookbackHours
        DomainControllerCount = $dcRows.Count
        ReachableCount = $reachableCount
        UnreachableCount = $unreachableCount
        ReplicationFailures = $replIssueCount
        FsmoIssues = $fsmoDown
        EventStats = @{
            TotalEvents = $allEvents.Count
            CriticalEvents = @($allEvents | Where-Object { $_.Severity -eq 'Critical' }).Count
            FailedLogonCount = @($allEvents | Where-Object { $_.EventID -eq '4625' }).Count
        }
        ShutdownEventStats = @{
            TotalShutdowns = $shutdownEvents.Count
            AffectedDCs = ($shutdownEvents | Select-Object -Property SourceDC -Unique).Count
        }
    }
    
    $jsonPayload | ConvertTo-Json -Depth 8 | Out-File -FilePath $jsonPath -Encoding UTF8
    
    Write-Log "==========================================================================" -Level OK
    Write-Log "              AD Daily Health Summary Complete" -Level OK
    Write-Log "==========================================================================" -Level OK
    Write-Log "HTML Report : $htmlPath" -Level OK
    Write-Log "DC CSV      : $dcCsv" -Level OK
    Write-Log "Events CSV  : $eventCsv" -Level OK
    Write-Log "Shutdowns CSV: $shutdownCsv" -Level OK
    Write-Log "==========================================================================" -Level OK
    
    [pscustomobject]@{
        HtmlReport = $htmlPath
        DcCsv = $dcCsv
        EventCsv = $eventCsv
        ShutdownCsv = $shutdownCsv
        JsonReport = $jsonPath
        OverallStatus = $healthStatus
        EventCount = $allEvents.Count
        UnexpectedShutdownCount = $shutdownEvents.Count
    }
}
catch {
    $errorMsg = $_.Exception.Message
    $stackTrace = $_.ScriptStackTrace
    Write-Log "FATAL ERROR: $errorMsg" -Level ERROR
    Write-Log "Stack Trace: $stackTrace" -Level ERROR
    
    [pscustomobject]@{
        Error = $errorMsg
        StackTrace = $stackTrace
    }
}

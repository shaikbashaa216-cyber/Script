<#
.SYNOPSIS
    Active Directory Daily Health Check with Comprehensive Event Log Monitoring
    
.DESCRIPTION
    Performs daily health checks on Active Directory including DC health, FSMO roles,
    replication status, and critical security event log analysis. Outputs HTML dashboard.
    
    Monitored Event IDs:
    - 4625: Failed logon (wrong passwords, expired accounts, password-spraying)
    - 4719: System audit policy modified
    - 4672: Special privileges assigned to new logon (admin login)
    - 4648: Logon attempted using explicit credentials
    - 1100: Event logging service shut down
    - 6008: Unexpected previous shutdown
    - 1074: Planned restart/shutdown initiated
    
.NOTES
    Run on a domain-joined server with ActiveDirectory module and admin privileges.
    Requires PowerShell 5.1 or later.
#>

[CmdletBinding()]
param(
    [Parameter(Mandatory = $false)]
    [string]$OutputDirectory = "C:\Temp\AD_Daily_Health",
    
    [Parameter(Mandatory = $false)]
    [switch]$IncludeReplicationText = $true,
    
    [Parameter(Mandatory = $false)]
    [switch]$Runbook,
    
    [Parameter(Mandatory = $false)]
    [switch]$DemoMode,
    
    [Parameter(Mandatory = $false)]
    [ValidateRange(1, 25)]
    [int]$DemoDomainControllerLimit = 3,
    
    [Parameter(Mandatory = $false)]
    [ValidateRange(1, 168)]
    [int]$EventLookbackHours = 24,
    
    [Parameter(Mandatory = $false)]
    [switch]$SkipEventLogs,
    
    [Parameter(Mandatory = $false)]
    [int]$PortCheckTimeoutMs = 2000
)

# Set strict error handling
$ErrorActionPreference = 'Continue'
$WarningPreference = 'SilentlyContinue'

# =============================================================================
# SECTION 1: LOGGING AND UTILITY FUNCTIONS
# =============================================================================

function Write-Log {
    param(
        [string]$Message,
        [string]$Level = 'INFO'
    )
    $ts = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'
    $color = switch ($Level) {
        'ERROR'   { 'Red' }
        'WARN'    { 'Yellow' }
        'OK'      { 'Green' }
        default   { 'Gray' }
    }
    Write-Host "[$ts] [$Level] $Message" -ForegroundColor $color
}

function Write-HealthRunbook {
    $lines = @(
        '═══════════════════════════════════════════════════════════════════════════════',
        '                    AD Daily Health Summary Runbook',
        '═══════════════════════════════════════════════════════════════════════════════',
        '',
        'Standard daily run:',
        '  powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1',
        '',
        'Custom output folder:',
        '  powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -OutputDirectory D:\Reports\ADHealth',
        '',
        'Extend event lookback period:',
        '  powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -EventLookbackHours 48',
        '',
        'Skip event log collection (faster runs):',
        '  powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -SkipEventLogs',
        '',
        'Demo mode (safe showcase output):',
        '  powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -DemoMode -DemoDomainControllerLimit 10',
        '',
        'Print this runbook only:',
        '  powershell -ExecutionPolicy Bypass -File .\AD_Daily_Health_Summary.ps1 -Runbook',
        '',
        '═══════════════════════════════════════════════════════════════════════════════'
    )
    Write-Host ($lines -join [Environment]::NewLine) -ForegroundColor Cyan
}

function HtmlSafe {
    param([object]$Value)
    if ($null -eq $Value) { return '' }
    try {
        return [System.Net.WebUtility]::HtmlEncode([string]$Value)
    }
    catch {
        return ''
    }
}

function Get-SvcBadge {
    param([string]$Status)
    $cls = if ($Status -eq 'Running') { 'svc-ok' } 
           elseif ($Status -eq 'Unknown') { 'svc-unk' } 
           else { 'svc-bad' }
    return "<span class='svc $cls'>$(HtmlSafe $Status)</span>"
}


# =============================================================================
# SECTION 2: IMPROVED CONNECTIVITY AND SERVICE DETECTION
# =============================================================================

function Test-DCReachability {
    <#
    .SYNOPSIS
        Tests if a domain controller is reachable using multiple methods
    #>
    param(
        [string]$ComputerName,
        [int]$TimeoutMs = 2000
    )
    
    # Method 1: Test-Connection (ICMP ping)
    try {
        $ping = Test-Connection -ComputerName $ComputerName -Count 1 -Quiet -ErrorAction Stop -TimeoutSeconds 5
        if ($ping) {
            Write-Log "$ComputerName is reachable via ICMP ping" -Level INFO
            return $true
        }
    }
    catch {
        Write-Log "ICMP ping to $ComputerName failed: $($_.Exception.Message)" -Level WARN
    }
    
    # Method 2: Test TCP port 445 (SMB - core AD service port)
    try {
        $tcpClient = New-Object System.Net.Sockets.TcpClient
        $asyncResult = $tcpClient.BeginConnect($ComputerName, 445, $null, $null)
        $wait = $asyncResult.AsyncWaitHandle.WaitOne($TimeoutMs)
        if ($wait) {
            $tcpClient.EndConnect($asyncResult)
            $tcpClient.Close()
            Write-Log "$ComputerName is reachable via TCP 445 (SMB)" -Level INFO
            return $true
        }
        $tcpClient.Close()
    }
    catch {
        Write-Log "TCP 445 test to $ComputerName failed: $($_.Exception.Message)" -Level WARN
    }
    
    # Method 3: Test TCP port 389 (LDAP)
    try {
        $tcpClient = New-Object System.Net.Sockets.TcpClient
        $asyncResult = $tcpClient.BeginConnect($ComputerName, 389, $null, $null)
        $wait = $asyncResult.AsyncWaitHandle.WaitOne($TimeoutMs)
        if ($wait) {
            $tcpClient.EndConnect($asyncResult)
            $tcpClient.Close()
            Write-Log "$ComputerName is reachable via TCP 389 (LDAP)" -Level INFO
            return $true
        }
        $tcpClient.Close()
    }
    catch {
        Write-Log "TCP 389 test to $ComputerName failed: $($_.Exception.Message)" -Level WARN
    }
    
    # Method 4: DNS resolution check
    try {
        $dnsResult = [System.Net.Dns]::GetHostAddresses($ComputerName)
        if ($dnsResult -and $dnsResult.Count -gt 0) {
            Write-Log "$ComputerName resolved to IP: $($dnsResult[0].IPAddressToString)" -Level INFO
            return $true
        }
    }
    catch {
        Write-Log "DNS resolution for $ComputerName failed: $($_.Exception.Message)" -Level WARN
    }
    
    Write-Log "$ComputerName is NOT reachable via any method" -Level WARN
    return $false
}

function Get-DCServicesImproved {
    <#
    .SYNOPSIS
        Gets service status for critical AD services using multiple methods
    #>
    param(
        [string]$ComputerName,
        [bool]$IsReachable
    )
    
    $services = @{ 
        NTDS = 'Unknown'
        Netlogon = 'Unknown'
        KDC = 'Unknown'
        DFSR = 'Unknown'
        DNS = 'Unknown'
    }
    
    if (-not $IsReachable) {
        Write-Log "$ComputerName is not reachable, skipping service checks" -Level WARN
        return $services
    }
    
    # Service names and their display names
    $serviceMap = @{
        'NTDS' = 'NTDS'
        'Netlogon' = 'Netlogon'
        'KDC' = 'kdc'
        'DFSR' = 'DFSR'
        'DNS' = 'DNS'
    }
    
    # Method 1: Get-Service with explicit credentials (using current context)
    foreach ($svcName in $serviceMap.Keys) {
        try {
            $svc = Get-Service -ComputerName $ComputerName -Name $serviceMap[$svcName] -ErrorAction Stop
            $services[$svcName] = $svc.Status.ToString()
            Write-Log "$ComputerName - $svcName service is $($svc.Status)" -Level INFO
        }
        catch {
            Write-Log "Get-Service failed for $ComputerName - $svcName : $($_.Exception.Message)" -Level WARN
            
            # Method 2: Try using WMI as fallback
            try {
                $wmiService = Get-CimInstance -ClassName Win32_Service -ComputerName $ComputerName -Filter "Name='$($serviceMap[$svcName])'" -ErrorAction Stop
                if ($wmiService) {
                    $services[$svcName] = $wmiService.State
                    Write-Log "$ComputerName - $svcName (via WMI) is $($wmiService.State)" -Level INFO
                }
            }
            catch {
                Write-Log "WMI also failed for $ComputerName - $svcName : $($_.Exception.Message)" -Level WARN
            }
        }
    }
    
    return $services
}

function Check-DCHealthImproved {
    <#
    .SYNOPSIS
        Comprehensive health check for a single domain controller
    #>
    param(
        [string]$HostName,
        [string]$Domain,
        [string]$Site,
        [string]$IPv4,
        [int]$PortCheckTimeoutMs
    )
    
    Write-Log "Checking DC: $HostName" -Level INFO
    
    # Test reachability using multiple methods
    $reachable = Test-DCReachability -ComputerName $HostName -TimeoutMs $PortCheckTimeoutMs
    
    # Get service status if reachable
    $services = Get-DCServicesImproved -ComputerName $HostName -IsReachable $reachable
    
    # Determine DC status
    $anyBad = $false
    $anyRunning = $false
    
    foreach ($svcName in @('NTDS', 'Netlogon', 'KDC')) {
        $status = $services[$svcName]
        if ($status -eq 'Running') {
            $anyRunning = $true
        }
        elseif ($status -ne 'Unknown' -and $status -ne 'Running') {
            $anyBad = $true
        }
    }
    
    # A DC is considered healthy if:
    # - It's reachable, AND
    # - At least NTDS is running (or we can't determine but it's reachable)
    $dcStatus = if (-not $reachable) { 
        'Red' 
    } 
    elseif ($anyBad) { 
        'Yellow' 
    }
    elseif ($anyRunning -or $reachable) {
        # If reachable, consider it at least Yellow/Green even if services unknown
        if ($services['NTDS'] -eq 'Running' -and $services['Netlogon'] -eq 'Running') {
            'Green'
        } else {
            'Yellow'
        }
    }
    else {
        'Yellow'
    }
    
    # Log final status
    Write-Log "$HostName - Reachable: $reachable, Status: $dcStatus, NTDS: $($services['NTDS'])" -Level INFO
    
    return [pscustomobject]@{
        Domain      = $Domain
        HostName    = $HostName
        Site        = $Site
        IPv4Address = $IPv4
        Reachable   = $reachable
        NTDS        = $services['NTDS']
        Netlogon    = $services['Netlogon']
        KDC         = $services['KDC']
        DFSR        = $services['DFSR']
        DNS         = $services['DNS']
        DcStatus    = $dcStatus
    }
}

function Collect-DCHealth {
    param(
        [array]$DomainControllers,
        [int]$PortCheckTimeoutMs
    )
    
    Write-Log "Collecting health for $($DomainControllers.Count) domain controllers..." -Level OK
    
    $dcRows = @()
    $total = $DomainControllers.Count
    $current = 0
    
    foreach ($dc in $DomainControllers) {
        $current++
        Write-Log "Processing DC $current of $total : $($dc.HostName)" -Level INFO
        
        try {
            $result = Check-DCHealthImproved -HostName $dc.HostName -Domain $dc.Domain -Site $dc.Site -IPv4 $dc.IPv4Address -PortCheckTimeoutMs $PortCheckTimeoutMs
            $dcRows += $result
        }
        catch {
            Write-Log "Failed to process DC $($dc.HostName): $($_.Exception.Message)" -Level ERROR
            # Add a placeholder for failed DC with more details
            $dcRows += [pscustomobject]@{
                Domain      = $dc.Domain
                HostName    = $dc.HostName
                Site        = $dc.Site
                IPv4Address = $dc.IPv4Address
                Reachable   = $false
                NTDS        = 'Error'
                Netlogon    = 'Error'
                KDC         = 'Error'
                DFSR        = 'Error'
                DNS         = 'Error'
                DcStatus    = 'Red'
            }
        }
    }
    
    $reachableCount = @($dcRows | Where-Object { $_.Reachable -eq $true }).Count
    Write-Log "Health collection complete. $reachableCount of $total DCs are reachable." -Level OK
    return $dcRows
}


# =============================================================================
# SECTION 3: EVENT LOG COLLECTION FUNCTIONS
# =============================================================================

function Get-EventsFromDC {
    param(
        [string]$ComputerName,
        [datetime]$StartTime
    )
    
    $events = @()
    
    # Define event details
    $eventDetails = @{
        '4625' = @{ Name = 'Failed Logon'; Severity = 'Warning'; LogName = 'Security'; Description = 'Wrong password, expired account, or potential password-spraying attack' }
        '4719' = @{ Name = 'System Audit Policy Modified'; Severity = 'Critical'; LogName = 'Security'; Description = 'Security auditing settings were modified' }
        '4672' = @{ Name = 'Special Privileges Assigned'; Severity = 'Warning'; LogName = 'Security'; Description = 'Admin privileges assigned to new logon' }
        '4648' = @{ Name = 'Explicit Credential Logon'; Severity = 'Warning'; LogName = 'Security'; Description = 'Logon attempted using explicit credentials' }
        '1100' = @{ Name = 'Event Log Service Shutdown'; Severity = 'Warning'; LogName = 'System'; Description = 'The event logging service has shut down' }
        '6008' = @{ Name = 'Unexpected Shutdown'; Severity = 'Critical'; LogName = 'System'; Description = 'Previous system shutdown was unexpected' }
        '1074' = @{ Name = 'Planned Restart/Shutdown'; Severity = 'Info'; LogName = 'System'; Description = 'Planned restart or shutdown initiated' }
    }
    
    # Security events
    $securityEventIds = @('4625', '4719', '4672', '4648')
    foreach ($eventId in $securityEventIds) {
        try {
            $filterHash = @{
                LogName = 'Security'
                ID = $eventId
                StartTime = $StartTime
            }
            $results = Get-WinEvent -ComputerName $ComputerName -FilterHashtable $filterHash -MaxEvents 50 -ErrorAction SilentlyContinue
            foreach ($evt in $results) {
                $details = $eventDetails[$eventId]
                $events += [pscustomobject]@{
                    SourceDC = $ComputerName
                    TimeCreated = $evt.TimeCreated
                    LogName = $details.LogName
                    EventID = $evt.Id
                    EventName = $details.Name
                    Severity = $details.Severity
                    Description = $details.Description
                    Message = ($evt.Message -replace "`r`n", ' ' -replace "`n", ' ') | Select-Object -First 300
                }
            }
        }
        catch {
            # Silently continue for permission issues
        }
    }
    
    # System events
    $systemEventIds = @('1100', '6008', '1074')
    foreach ($eventId in $systemEventIds) {
        try {
            $filterHash = @{
                LogName = 'System'
                ID = $eventId
                StartTime = $StartTime
            }
            $results = Get-WinEvent -ComputerName $ComputerName -FilterHashtable $filterHash -MaxEvents 50 -ErrorAction SilentlyContinue
            foreach ($evt in $results) {
                $details = $eventDetails[$eventId]
                $events += [pscustomobject]@{
                    SourceDC = $ComputerName
                    TimeCreated = $evt.TimeCreated
                    LogName = $details.LogName
                    EventID = $evt.Id
                    EventName = $details.Name
                    Severity = $details.Severity
                    Description = $details.Description
                    Message = ($evt.Message -replace "`r`n", ' ' -replace "`n", ' ') | Select-Object -First 300
                }
            }
        }
        catch {
            # Silently continue for permission issues
        }
    }
    
    return $events
}

function Collect-AllEvents {
    param(
        [array]$DomainControllers,
        [datetime]$StartTime
    )
    
    $allEvents = @()
    $securityCount = 0
    $systemCount = 0
    
    Write-Log "Collecting event logs from $($DomainControllers.Count) domain controllers..." -Level OK
    
    $total = $DomainControllers.Count
    $current = 0
    
    foreach ($dc in $DomainControllers) {
        $current++
        Write-Log "Processing events from DC $current of $total : $($dc.HostName)" -Level INFO
        
        try {
            $events = Get-EventsFromDC -ComputerName $dc.HostName -StartTime $StartTime
            foreach ($event in $events) {
                $allEvents += $event
                if ($event.LogName -eq 'Security') { $securityCount++ }
                if ($event.LogName -eq 'System') { $systemCount++ }
            }
        }
        catch {
            Write-Log "Failed to collect events from $($dc.HostName): $($_.Exception.Message)" -Level WARN
        }
    }
    
    Write-Log "Event collection complete: Security=$securityCount, System=$systemCount, Total=$($allEvents.Count)" -Level OK
    
    return $allEvents
}


# =============================================================================
# SECTION 4: AD STRUCTURE FUNCTIONS
# =============================================================================

function Get-FSMORoleStatus {
    param($Domain, $Forest)
    
    $fsmoRows = @()
    
    # PDC Emulator
    try {
        $holder = $Domain.PDCEmulator
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 2000
        $fsmoRows += [pscustomobject]@{ Role = 'PDC Emulator'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'PDC Emulator'; Holder = 'Unknown'; Reachable = $false }
    }
    
    # RID Master
    try {
        $holder = $Domain.RIDMaster
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 2000
        $fsmoRows += [pscustomobject]@{ Role = 'RID Master'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'RID Master'; Holder = 'Unknown'; Reachable = $false }
    }
    
    # Infrastructure Master
    try {
        $holder = $Domain.InfrastructureMaster
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 2000
        $fsmoRows += [pscustomobject]@{ Role = 'Infrastructure Master'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'Infrastructure Master'; Holder = 'Unknown'; Reachable = $false }
    }
    
    # Schema Master
    try {
        $holder = $Forest.SchemaMaster
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 2000
        $fsmoRows += [pscustomobject]@{ Role = 'Schema Master'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'Schema Master'; Holder = 'Unknown'; Reachable = $false }
    }
    
    # Domain Naming Master
    try {
        $holder = $Forest.DomainNamingMaster
        $ok = Test-DCReachability -ComputerName $holder -TimeoutMs 2000
        $fsmoRows += [pscustomobject]@{ Role = 'Domain Naming Master'; Holder = $holder; Reachable = $ok }
    }
    catch {
        $fsmoRows += [pscustomobject]@{ Role = 'Domain Naming Master'; Holder = 'Unknown'; Reachable = $false }
    }
    
    return $fsmoRows
}

function Get-ReplicationFailures {
    $replFailureRows = @()
    try {
        $replFailures = @(Get-ADReplicationFailure -Scope Forest -ErrorAction Stop)
        foreach ($f in $replFailures) {
            $replFailureRows += [pscustomobject]@{
                Server = [string]$f.Server
                Partner = [string]$f.Partner
                LastError = [string]$f.LastError
                FailureCount = [int]$f.FailureCount
                FirstFailureTime = $f.FirstFailureTime
                LastFailureTime = $f.LastFailureTime
            }
        }
    }
    catch {
        Write-Log "Get-ADReplicationFailure failed: $($_.Exception.Message)" -Level WARN
    }
    
    return $replFailureRows
}

function Get-ReplicationSummaryText {
    $replText = ''
    if ($IncludeReplicationText -and (Get-Command repadmin.exe -ErrorAction SilentlyContinue)) {
        try {
            $replText = & repadmin.exe /replsummary 2>&1 | Out-String
            if ([string]::IsNullOrWhiteSpace($replText)) {
                $replText = 'No replication issues detected.'
            }
        }
        catch {
            $replText = "repadmin failed: $($_.Exception.Message)"
        }
    }
    elseif (-not $IncludeReplicationText) {
        $replText = 'Replication summary skipped'
    }
    else {
        $replText = 'repadmin.exe not found in PATH'
    }
    
    return $replText
}

function Get-SiteStatistics {
    param([array]$DcRows)
    
    $siteStats = @()
    $siteGroups = $DcRows | Group-Object -Property Site
    
    foreach ($group in $siteGroups) {
        $sg = @($group.Group)
        $sRed = @($sg | Where-Object { $_.DcStatus -eq 'Red' }).Count
        $sYel = @($sg | Where-Object { $_.DcStatus -eq 'Yellow' }).Count
        $sGrn = @($sg | Where-Object { $_.DcStatus -eq 'Green' }).Count
        $sColor = if ($sRed -gt 0) { 'red' } elseif ($sYel -gt 0) { 'yellow' } else { 'green' }
        
        $siteStats += [pscustomobject]@{
            Site = [string]$group.Name
            Total = $sg.Count
            Red = $sRed
            Yellow = $sYel
            Green = $sGrn
            Color = $sColor
        }
    }
    
    $siteStats = $siteStats | Sort-Object Color, Site
    return $siteStats
}


# =============================================================================
# SECTION 5: HTML GENERATION FUNCTIONS
# =============================================================================

function Build-SiteCardsHtml {
    param([array]$SiteStats)
    
    $html = @()
    foreach ($stat in $SiteStats) {
        $statusLine = if ($stat.Red -gt 0) { "$($stat.Red) unreachable" }
                      elseif ($stat.Yellow -gt 0) { "$($stat.Yellow) service issue" }
                      else { 'All healthy' }
        $dcText = if ($stat.Total -eq 1) { '1 DC' } else { "$($stat.Total) DCs" }
        
        $html += "<div class='site-card site-$($stat.Color)'>" +
                 "<div class='site-name'>$(HtmlSafe $stat.Site)</div>" +
                 "<div class='site-count'>$dcText</div>" +
                 "<div class='site-status'>$statusLine</div>" +
                 "</div>"
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-PriorityIssuesHtml {
    param([array]$DcRows)
    
    $issueRows = @($DcRows | Where-Object { $_.DcStatus -ne 'Green' })
    
    if ($issueRows.Count -eq 0) {
        return "<tr><td colspan='9' style='text-align:center'>No issues detected in this run</td></tr>"
    }
    
    $html = @()
    foreach ($dc in ($issueRows | Sort-Object DcStatus, Site, HostName)) {
        $rc = if ($dc.DcStatus -eq 'Red') { 'row-red' } else { 'row-yellow' }
        $html += "<tr class='$rc'>" +
                 "<td>$(HtmlSafe $dc.Site)</td>" +
                 "<td>$(HtmlSafe $dc.HostName)</td>" +
                 "<td>$(HtmlSafe $dc.IPv4Address)</td>" +
                 "<td>$(HtmlSafe $dc.Reachable)</td>" +
                 "<td>$(Get-SvcBadge $dc.NTDS)</td>" +
                 "<td>$(Get-SvcBadge $dc.Netlogon)</td>" +
                 "<td>$(Get-SvcBadge $dc.KDC)</td>" +
                 "<td>$(Get-SvcBadge $dc.DFSR)</td>" +
                 "<td>$(Get-SvcBadge $dc.DNS)</td>" +
                 "</tr>"
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-FSMOHtml {
    param([array]$FsmoRows)
    
    $html = @()
    foreach ($fsmo in $FsmoRows) {
        $rc = if (-not $fsmo.Reachable) { 'row-red' } else { '' }
        $icon = if ($fsmo.Reachable) { "<span class='svc svc-ok'>Reachable</span>" } 
                else { "<span class='svc svc-bad'>UNREACHABLE</span>" }
        $html += "<tr class='$rc'>" +
                 "<td>$(HtmlSafe $fsmo.Role)</td>" +
                 "<td>$(HtmlSafe $fsmo.Holder)</td>" +
                 "<td>$icon</td>" +
                 "</tr>"
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-ReplicationFailHtml {
    param([array]$ReplFailureRows)
    
    if ($ReplFailureRows.Count -eq 0) {
        return "<tr><td colspan='6'>No replication failures detected across the forest.</td></tr>"
    }
    
    $html = @()
    foreach ($r in ($ReplFailureRows | Sort-Object FailureCount -Descending)) {
        $html += "<tr class='row-yellow'>" +
                 "<td>$(HtmlSafe $r.Server)</td>" +
                 "<td>$(HtmlSafe $r.Partner)</td>" +
                 "<td>$(HtmlSafe $r.LastError)</td>" +
                 "<td>$(HtmlSafe $r.FailureCount)</td>" +
                 "<td>$(HtmlSafe $r.FirstFailureTime)</td>" +
                 "<td>$(HtmlSafe $r.LastFailureTime)</td>" +
                 "</table>"
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-DCSiteSectionsHtml {
    param([array]$DcRows)
    
    $html = @()
    $siteGroups = $DcRows | Group-Object -Property Site | Sort-Object Name
    
    foreach ($group in $siteGroups) {
        $siteName = [string]$group.Name
        $safeId = $siteName -replace '[^a-zA-Z0-9]', '_'
        $siteDcs = @($group.Group | Sort-Object DcStatus, HostName)
        $sRed = @($siteDcs | Where-Object { $_.DcStatus -eq 'Red' }).Count
        $sYel = @($siteDcs | Where-Object { $_.DcStatus -eq 'Yellow' }).Count
        $badgeColor = if ($sRed -gt 0) { 'red' } elseif ($sYel -gt 0) { 'yellow' } else { 'green' }
        $badgeLabel = if ($sRed -gt 0) { "Red ($sRed unreachable)" } 
                      elseif ($sYel -gt 0) { "Yellow ($sYel issue)" } 
                      else { 'Green' }
        $dcCountText = if ($siteDcs.Count -eq 1) { '1 DC' } else { "$($siteDcs.Count) DCs" }
        
        $rows = @()
        foreach ($dc in $siteDcs) {
            $rc = switch ($dc.DcStatus) { 
                'Red' { 'dc-row row-red' } 
                'Yellow' { 'dc-row row-yellow' } 
                default { 'dc-row' } 
            }
            $reachIcon = if ($dc.Reachable) { "<span class='svc svc-ok'>✓</span>" } 
                         else { "<span class='svc svc-bad'>✗</span>" }
            $search = ($dc.HostName + ' ' + $dc.IPv4Address + ' ' + $dc.Site).ToLower()
            
            $rows += "<tr class='$rc' data-search='$(HtmlSafe $search)'>" +
                     "<td>$(HtmlSafe $dc.HostName)</td>" +
                     "<td>$(HtmlSafe $dc.IPv4Address)</td>" +
                     "<td>$reachIcon</td>" +
                     "<td>$(Get-SvcBadge $dc.NTDS)</td>" +
                     "<td>$(Get-SvcBadge $dc.Netlogon)</td>" +
                     "<td>$(Get-SvcBadge $dc.KDC)</td>" +
                     "<td>$(Get-SvcBadge $dc.DFSR)</td>" +
                     "<td>$(Get-SvcBadge $dc.DNS)</td>" +
                     "</tr>"
        }
        
        $block = "<div class='site-section'>"
        $block += "<div class='site-header' onclick='toggleSite(`"$safeId`")'>"
        $block += "<span class='badge badge-$badgeColor'>$badgeLabel</span>"
        $block += "<strong>$(HtmlSafe $siteName)</strong>"
        $block += "<span class='dc-count'>$dcCountText</span>"
        $block += "<span class='toggle-hint'>(click to expand)</span></div>"
        $block += "<div id='site-$safeId' class='site-table' style='display:none'>"
        $block += "<table><thead>"
        $block += "<tr><th>Domain Controller</th><th>IP Address</th><th>Reachable</th>"
        $block += "<th>NTDS</th><th>Netlogon</th><th>KDC</th><th>DFSR</th><th>DNS</th></tr>"
        $block += "</thead><tbody>" + ($rows -join [Environment]::NewLine) + "</tbody>"
        $block += "</div></div>"
        
        $html += $block
    }
    
    return ($html -join [Environment]::NewLine)
}

function Build-EventsHtml {
    param([array]$Events)
    
    if ($Events.Count -eq 0) {
        return "<div class='no-events'>No events detected in the last $EventLookbackHours hour(s).</div>"
    }
    
    $severityOrder = @{ 'Critical' = 1; 'Warning' = 2; 'Info' = 3 }
    $sortedEvents = $Events | Sort-Object { $severityOrder[[string]$_.Severity] }, TimeCreated -Descending
    
    $html = "<thead>"
    $html += "<tr><th>Time</th><th>Source DC</th><th>Event ID</th><th>Event Name</th><th>Severity</th><th>Description</th><th>Message</th></tr>"
    $html += "</thead><tbody>"
    
    $count = 0
    foreach ($event in $sortedEvents) {
        if ($count -ge 200) { 
            $html += "<tr><td colspan='7' class='text-center'>... and $($Events.Count - 200) more events (see CSV export for full list)</td></tr>"
            break 
        }
        
        $severityClass = switch ($event.Severity) {
            'Critical' { 'event-critical' }
            'Warning'  { 'event-warning' }
            default    { 'event-info' }
        }
        
        $shortMessage = $event.Message
        if ($shortMessage.Length -gt 200) {
            $shortMessage = $shortMessage.Substring(0, 200) + "..."
        }
        
        $html += "<tr class='$severityClass'>"
        $html += "<td>$($event.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))</td>"
        $html += "<td>$(HtmlSafe $event.SourceDC)</td>"
        $html += "<td>$($event.EventID)</td>"
        $html += "<td>$(HtmlSafe $event.EventName)</td>"
        $html += "<td><span class='event-badge $severityClass'>$(HtmlSafe $event.Severity)</span></td>"
        $html += "<td><div class='event-message'>$(HtmlSafe $event.Description)</div></td>"
        $html += "<td><div class='event-message'>$(HtmlSafe $shortMessage)</div></td>"
        $html += "<tr>"
        $count++
    }
    
    $html += "</tbody>"
    return $html
}

function Build-EventStatsCards {
    param([array]$Events)
    
    $criticalCount = @($Events | Where-Object { $_.Severity -eq 'Critical' }).Count
    $warningCount = @($Events | Where-Object { $_.Severity -eq 'Warning' }).Count
    $infoCount = @($Events | Where-Object { $_.Severity -eq 'Info' }).Count
    
    $totalEvents = $Events.Count    
    $failedLogonCount = @($Events | Where-Object { $_.EventID -eq '4625' }).Count
    $auditChangeCount = @($Events | Where-Object { $_.EventID -eq '4719' }).Count
    $adminLoginCount = @($Events | Where-Object { $_.EventID -eq '4672' }).Count
    $explicitCredCount = @($Events | Where-Object { $_.EventID -eq '4648' }).Count
    $unexpectedShutdownCount = @($Events | Where-Object { $_.EventID -eq '6008' }).Count
    
    $html = "<div class='cards'>"
    $html += "<div class='card'><div class='k'>Total Events</div><div class='v'>$totalEvents</div></div>"
    $html += "<div class='card event-critical'><div class='k'>Critical</div><div class='v'>$criticalCount</div></div>"
    $html += "<div class='card event-warning'><div class='k'>Warning</div><div class='v'>$warningCount</div></div>"
    $html += "<div class='card event-info'><div class='k'>Informational</div><div class='v'>$infoCount</div></div>"
    $html += "</div>"
    
    $html += "<div class='cards' style='margin-top: 10px;'>"
    $html += "<div class='card'><div class='k'>Failed Logons (4625)</div><div class='v'>$failedLogonCount</div><div class='detail'>Password spraying indicator</div></div>"
    $html += "<div class='card'><div class='k'>Audit Changes (4719)</div><div class='v'>$auditChangeCount</div><div class='detail'>Security settings modified</div></div>"
    $html += "<div class='card'><div class='k'>Admin Logins (4672)</div><div class='v'>$adminLoginCount</div><div class='detail'>Special privileges assigned</div></div>"
    $html += "<div class='card'><div class='k'>Explicit Cred (4648)</div><div class='v'>$explicitCredCount</div><div class='detail'>Credential logon attempt</div></div>"
    $html += "<div class='card'><div class='k'>Unexpected Shutdown (6008)</div><div class='v'>$unexpectedShutdownCount</div><div class='detail'>System crash or power loss</div></div>"
    $html += "</div>"
    
    return $html
}


# =============================================================================
# SECTION 6: MAIN EXECUTION
# =============================================================================

try {
    # Display runbook if requested
    if ($Runbook) {
        Write-HealthRunbook
        return
    }
    
    # Create output directory
    if (-not (Test-Path -LiteralPath $OutputDirectory)) {
        New-Item -ItemType Directory -Path $OutputDirectory -Force | Out-Null
        Write-Log "Created output directory: $OutputDirectory" -Level OK
    }
    
    Write-Log "═══════════════════════════════════════════════════════════════════════════════" -Level OK
    Write-Log "              AD Daily Health Summary - Starting Collection" -Level OK
    Write-Log "═══════════════════════════════════════════════════════════════════════════════" -Level OK
    
    # Load Active Directory module
    Write-Log "Loading ActiveDirectory module..." -Level INFO
    Import-Module ActiveDirectory -ErrorAction Stop
    Write-Log "ActiveDirectory module loaded successfully." -Level OK
    
    # Get AD structure
    Write-Log "Getting AD forest and domain information..." -Level INFO
    $domain = Get-ADDomain
    $forest = Get-ADForest
    $allDcs = @(Get-ADDomainController -Filter *)
    
    Write-Log "Domain: $($domain.DNSRoot)" -Level INFO
    Write-Log "Forest: $($forest.Name)" -Level INFO
    Write-Log "Total Domain Controllers: $($allDcs.Count)" -Level INFO
    
    # Apply demo mode limit
    if ($DemoMode -and $allDcs.Count -gt $DemoDomainControllerLimit) {
        $allDcs = @($allDcs | Sort-Object HostName | Select-Object -First $DemoDomainControllerLimit)
        Write-Log "Demo mode: limited to first $DemoDomainControllerLimit domain controllers." -Level WARN
    }
    
    # Collect DC health
    $dcRows = Collect-DCHealth -DomainControllers $allDcs -PortCheckTimeoutMs $PortCheckTimeoutMs
    
    # Collect FSMO and replication data
    Write-Log "Collecting FSMO role status..." -Level INFO
    $fsmoRows = Get-FSMORoleStatus -Domain $domain -Forest $forest
    
    Write-Log "Collecting replication failures..." -Level INFO
    $replFailureRows = Get-ReplicationFailures
    
    Write-Log "Getting replication summary..." -Level INFO
    $replText = Get-ReplicationSummaryText
    
    Write-Log "Calculating site statistics..." -Level INFO
    $siteStats = Get-SiteStatistics -DcRows $dcRows
    
    # Collect events (if not skipped)
    $allEvents = @()
    if (-not $SkipEventLogs) {
        $startTime = (Get-Date).AddHours(-$EventLookbackHours)
        Write-Log "Collecting events from last $EventLookbackHours hour(s)..." -Level INFO
        Write-Log "Monitoring Event IDs: 4625, 4719, 4672, 4648, 1100, 6008, 1074" -Level INFO
        $allEvents = Collect-AllEvents -DomainControllers $allDcs -StartTime $startTime
    } else {
        Write-Log "Event collection skipped (SkipEventLogs = true)" -Level WARN
    }
    
    # Calculate health status
    $reachableCount = @($dcRows | Where-Object { $_.Reachable -eq $true }).Count
    $unreachableCount = @($dcRows | Where-Object { $_.Reachable -eq $false }).Count
    $issueRows = @($dcRows | Where-Object { $_.DcStatus -ne 'Green' })
    $fsmoDown = @($fsmoRows | Where-Object { -not $_.Reachable }).Count
    $replIssueCount = $replFailureRows.Count
    
    $healthStatus = if ($unreachableCount -gt 0 -or $fsmoDown -gt 0) { 'Red' }
                    elseif ($issueRows.Count -gt 0 -or $replIssueCount -gt 0) { 'Yellow' }
                    else { 'Green' }
    
    $escalationGuidance = switch ($healthStatus) {
        'Red'    { '⚠️ IMMEDIATE ACTION: One or more domain controllers or FSMO role holders are unreachable. Investigate immediately.' }
        'Yellow' { '⚠️ ATTENTION: Service degradation or replication failures detected. Review the issues below.' }
        default  { '✅ All domain controllers and FSMO role holders are healthy. Continue daily monitoring.' }
    }
    
    # Build HTML fragments
    Write-Log "Building HTML report..." -Level INFO
    $siteCardsHtml = Build-SiteCardsHtml -SiteStats $siteStats
    $priorityHtml = Build-PriorityIssuesHtml -DcRows $dcRows
    $fsmoHtml = Build-FSMOHtml -FsmoRows $fsmoRows
    $replFailHtml = Build-ReplicationFailHtml -ReplFailureRows $replFailureRows
    $siteGroupHtml = Build-DCSiteSectionsHtml -DcRows $dcRows
    $eventStatsHtml = Build-EventStatsCards -Events $allEvents
    $eventsHtml = Build-EventsHtml -Events $allEvents
    
    # Generate output paths
    $stamp = Get-Date -Format 'yyyyMMdd_HHmmss'
    $htmlPath = Join-Path $OutputDirectory "AD_Daily_Health_Summary_$stamp.html"
    $dcCsv = Join-Path $OutputDirectory "AD_Daily_Health_DCs_$stamp.csv"
    $eventCsv = Join-Path $OutputDirectory "AD_Daily_Health_Events_$stamp.csv"
    $jsonPath = Join-Path $OutputDirectory "AD_Daily_Health_Summary_$stamp.json"
    
    # Export CSV files
    Write-Log "Exporting CSV files..." -Level INFO
    $dcRows | Export-Csv -Path $dcCsv -NoTypeInformation -Encoding UTF8
    $allEvents | Export-Csv -Path $eventCsv -NoTypeInformation -Encoding UTF8
    Write-Log "Exported DC CSV: $dcCsv" -Level OK
    Write-Log "Exported Events CSV: $eventCsv" -Level OK
    
    # Generate HTML content (same as before - keeping it compact)
    $htmlContent = @"
<!DOCTYPE html>
<html lang='en'>
<head>
<meta charset='UTF-8' />
<meta name='viewport' content='width=device-width, initial-scale=1.0' />
<title>AD Daily Health Summary</title>
<style>
:root { 
    --bg1:#eaf3ff; 
    --bg2:#dbeafe; 
    --panel:#ffffff; 
    --border:#bfd6f6; 
    --title:#0f2a56; 
    --text:#16335f; 
    --muted:#47678f; 
    --head:#e1eeff;
    --green:#22c55e;
    --green-bg:#f0fdf4;
    --yellow:#f59e0b;
    --yellow-bg:#fffbeb;
    --red:#ef4444;
    --red-bg:#fef2f2;
    --blue:#3b82f6;
    --blue-bg:#eff6ff;
}
* { box-sizing: border-box; }
body { 
    font-family: 'Segoe UI', Arial, sans-serif; 
    margin: 0; 
    padding: 16px; 
    background: linear-gradient(160deg, var(--bg1) 0%, var(--bg2) 100%); 
    color: var(--text); 
    min-height: 100vh; 
}
h1, h2 { margin: 0 0 8px 0; color: var(--title); }
.panel { 
    background: var(--panel); 
    border: 1px solid var(--border); 
    border-radius: 12px; 
    padding: 14px; 
    margin-bottom: 14px; 
    box-shadow: 0 3px 12px rgba(22,74,140,0.08); 
}
.meta { color: var(--muted); font-size: 13px; margin-top: 4px; }
.cards { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; }
.card { 
    background: linear-gradient(180deg,#ffffff 0%,#f0f7ff 100%); 
    border: 1px solid var(--border); 
    border-radius: 12px; 
    padding: 10px 16px; 
    min-width: 130px; 
}
.k { font-size: 11px; text-transform: uppercase; color: var(--muted); letter-spacing: .05em; }
.v { font-size: 26px; font-weight: 700; color: var(--title); }
.badge { 
    display: inline-block; 
    padding: 3px 10px; 
    border-radius: 999px; 
    font-weight: 600; 
    font-size: 12px; 
}
.badge-green  { background: var(--green-bg); color: #166534; }
.badge-yellow { background: var(--yellow-bg); color: #92400e; }
.badge-red    { background: var(--red-bg); color: #991b1b; }
.esc { padding: 10px 14px; border-radius: 8px; font-weight: 500; }
.esc-green  { background: var(--green-bg); border-left: 4px solid var(--green); color: #14532d; }
.esc-yellow { background: var(--yellow-bg); border-left: 4px solid var(--yellow); color: #78350f; }
.esc-red    { background: var(--red-bg); border-left: 4px solid var(--red); color: #7f1d1d; }
.site-grid { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
.site-card { border-radius: 10px; padding: 10px 14px; min-width: 155px; }
.site-green  { background: var(--green-bg); border: 1px solid #86efac; }
.site-yellow { background: var(--yellow-bg); border: 1px solid #fcd34d; }
.site-red    { background: var(--red-bg); border: 1px solid #fca5a5; }
.site-name   { font-weight: 600; font-size: 13px; color: var(--title); }
.site-count  { font-size: 11px; color: var(--muted); }
.site-status { font-size: 12px; font-weight: 500; margin-top: 2px; }
.site-green .site-status { color: #166534; }
.site-yellow .site-status { color: #92400e; }
.site-red .site-status { color: #991b1b; }
.site-section { margin-bottom: 6px; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
.site-header { 
    background: var(--head); 
    padding: 9px 14px; 
    cursor: pointer; 
    display: flex; 
    align-items: center; 
    gap: 10px; 
    user-select: none; 
}
.site-header:hover { background: #cde5ff; }
.dc-count { color: var(--muted); font-size: 12px; }
.toggle-hint { color: var(--muted); font-size: 11px; margin-left: auto; }
.site-table { padding: 0; }
table { border-collapse: collapse; width: 100%; font-size: 12px; background: #fff; }
th, td { border: 1px solid #d4e4fb; padding: 6px 8px; text-align: left; vertical-align: middle; }
th { background: var(--head); color: var(--title); font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
.row-red td { background: var(--red-bg); }
.row-yellow td { background: var(--yellow-bg); }
.svc { display: inline-block; padding: 2px 7px; border-radius: 4px; font-size: 11px; font-weight: 500; }
.svc-ok  { background: var(--green-bg); color: #166534; }
.svc-bad { background: var(--red-bg); color: #991b1b; }
.svc-unk { background: #f1f5f9; color: #64748b; }
.event-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; }
.event-critical { background: var(--red-bg); color: #991b1b; }
.event-warning { background: var(--yellow-bg); color: #92400e; }
.event-info { background: var(--blue-bg); color: #1e40af; }
.event-message { max-width: 500px; white-space: normal; word-break: break-word; font-size: 11px; line-height: 1.4; }
.no-events { padding: 20px; text-align: center; color: var(--muted); }
.text-center { text-align: center; }
.search-bar { 
    width: 100%; 
    padding: 8px 12px; 
    border: 1px solid var(--border); 
    border-radius: 8px; 
    font-size: 13px; 
    margin-bottom: 10px; 
    color: var(--text); 
    background: #fff; 
}
.search-bar:focus { outline: 2px solid var(--blue); border-color: var(--blue); }
pre { 
    background: #0f172a; 
    color: #e2e8f0; 
    padding: 12px; 
    border-radius: 8px; 
    overflow-x: auto; 
    font-size: 12px; 
    line-height: 1.5; 
}
</style>
</head>
<body>

<div class='panel'>
<h1>🏥 Active Directory Daily Health Summary</h1>
<div class='meta'>Generated: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')</div>
<div class='meta'>Domain: $(HtmlSafe $domain.DNSRoot) | Forest: $(HtmlSafe $forest.Name) | Domain Controllers: $($dcRows.Count) | AD Sites: $($siteStats.Count)</div>
<div class='meta'>Event Lookback: $EventLookbackHours hour(s) | Collection Mode: $(if ($DemoMode) { 'Demo' } else { 'Production' })</div>
<div class='meta'>Monitored Events: 4625, 4719, 4672, 4648, 1100, 6008, 1074</div>
</div>

<div class='cards'>
<div class='card'><div class='k'>Overall Health</div><div class='v'><span class='badge badge-$($healthStatus.ToLowerInvariant())'>$(HtmlSafe $healthStatus)</span></div></div>
<div class='card'><div class='k'>Domain Controllers</div><div class='v'>$($dcRows.Count)</div></div>
<div class='card'><div class='k'>Reachable</div><div class='v'>$reachableCount</div></div>
<div class='card'><div class='k'>Unreachable</div><div class='v'>$unreachableCount</div></div>
<div class='card'><div class='k'>Service Issues</div><div class='v'>$($issueRows.Count)</div></div>
<div class='card'><div class='k'>Replication Failures</div><div class='v'>$replIssueCount</div></div>
<div class='card'><div class='k'>FSMO Issues</div><div class='v'>$fsmoDown</div></div>
</div>

<div class='panel'>
<div class='esc esc-$($healthStatus.ToLowerInvariant())'>$(HtmlSafe $escalationGuidance)</div>
</div>

<div class='panel'>
<h2>🌐 Site Health Overview</h2>
<div class='meta'>One box per AD site. Red = unreachable DC. Yellow = service degradation. Green = all healthy.</div>
<div class='site-grid'>
$siteCardsHtml
</div>
</div>

<div class='panel'>
<h2>⚠️ Priority Issues</h2>
<div class='table-wrapper'>
<table>
<thead>
<tr><th>Site</th><th>Domain Controller</th><th>IP</th><th>Reachable</th><th>NTDS</th><th>Netlogon</th><th>KDC</th><th>DFSR</th><th>DNS</th></tr>
</thead>
<tbody>
$priorityHtml
</tbody>
</table>
</div>
</div>

<div class='panel'>
<h2>📋 Security & System Events (Last $EventLookbackHours Hours)</h2>
$eventStatsHtml
<div class='table-wrapper' style='max-height: 500px; overflow-y: auto;'>
<table>
$eventsHtml
</table>
</div>
<div class='meta' style='margin-top: 10px;'>Full event list exported to CSV: $(Split-Path $eventCsv -Leaf)</div>
</div>

<div class='panel'>
<h2>👑 FSMO Role Holders</h2>
<div class='table-wrapper'>
<table>
<thead><tr><th>Role</th><th>Holder</th><th>Status</th></tr></thead>
<tbody>$fsmoHtml</tbody>
</table>
</div>
</div>

<div class='panel'>
<h2>🔄 Replication Failures</h2>
<div class='table-wrapper'>
<table>
<thead><tr><th>Server</th><th>Partner</th><th>Last Error</th><th>Failure Count</th><th>First Failure</th><th>Last Failure</th></tr></thead>
<tbody>$replFailHtml</tbody>
</table>
</div>
</div>

<div class='panel'>
<h2>📊 Replication Summary (repadmin /replsummary)</h2>
<pre>$(HtmlSafe $replText)</pre>
</div>

<div class='panel'>
<h2>🖥️ All Domain Controllers by Site</h2>
<div class='meta'>$($dcRows.Count) DCs across $($siteStats.Count) sites. Click any site header to expand. Use search to filter.</div>
<input class='search-bar' type='text' id='dcSearch' placeholder='🔍 Search by DC name, IP address, or site...' oninput='filterDCs(this.value)' />
$siteGroupHtml
</div>

<div class='panel'>
<div class='meta' style='text-align: center;'>
<strong>Output Files:</strong><br/>
📄 HTML Report: $(Split-Path $htmlPath -Leaf)<br/>
📊 DC CSV: $(Split-Path $dcCsv -Leaf)<br/>
📋 Events CSV: $(Split-Path $eventCsv -Leaf)<br/>
📦 JSON: $(Split-Path $jsonPath -Leaf)
</div>
</div>

<script>
function toggleSite(id) {
    var el = document.getElementById('site-' + id);
    if (el) { el.style.display = (el.style.display === 'none') ? '' : 'none'; }
}

function filterDCs(val) {
    var lower = val.toLowerCase().trim();
    var rows = document.querySelectorAll('.dc-row');
    rows.forEach(function(r) {
        var sd = r.getAttribute('data-search') || '';
        r.style.display = lower === '' ? '' : (sd.indexOf(lower) > -1 ? '' : 'none');
    });
    var tables = document.querySelectorAll('.site-table');
    tables.forEach(function(t) {
        if (lower !== '') { t.style.display = ''; }
    });
}
</script>

</body>
</html>
"@

    # Save HTML file
    [System.IO.File]::WriteAllText($htmlPath, $htmlContent, [System.Text.Encoding]::UTF8)
    
    # Save JSON payload
    $jsonPayload = [pscustomobject]@{
        GeneratedOn = (Get-Date).ToString('s')
        Domain = [string]$domain.DNSRoot
        Forest = [string]$forest.Name
        HealthStatus = $healthStatus
        EscalationGuidance = $escalationGuidance
        EventLookbackHours = $EventLookbackHours
        DomainControllerCount = $dcRows.Count
        SiteCount = $siteStats.Count
        ReachableCount = $reachableCount
        UnreachableCount = $unreachableCount
        ServiceIssueCount = $issueRows.Count
        ReplicationFailures = $replIssueCount
        FsmoIssues = $fsmoDown
        EventStats = @{
            TotalEvents = $allEvents.Count
            CriticalEvents = @($allEvents | Where-Object { $_.Severity -eq 'Critical' }).Count
            WarningEvents = @($allEvents | Where-Object { $_.Severity -eq 'Warning' }).Count
            InfoEvents = @($allEvents | Where-Object { $_.Severity -eq 'Info' }).Count
            FailedLogonCount = @($allEvents | Where-Object { $_.EventID -eq '4625' }).Count
            AuditChangeCount = @($allEvents | Where-Object { $_.EventID -eq '4719' }).Count
            AdminLoginCount = @($allEvents | Where-Object { $_.EventID -eq '4672' }).Count
            ExplicitCredCount = @($allEvents | Where-Object { $_.EventID -eq '4648' }).Count
            UnexpectedShutdownCount = @($allEvents | Where-Object { $_.EventID -eq '6008' }).Count
        }
        SiteStats = @($siteStats)
        DomainControllers = @($dcRows | Select-Object Domain, HostName, Site, Reachable, DcStatus)
        FsmoRoles = @($fsmoRows)
        ReplicationFailureRows = @($replFailureRows)
        MonitoredEvents = @('4625', '4719', '4672', '4648', '1100', '6008', '1074')
    }
    
    $jsonPayload | ConvertTo-Json -Depth 8 | Out-File -FilePath $jsonPath -Encoding UTF8
    
    Write-Log "═══════════════════════════════════════════════════════════════════════════════" -Level OK
    Write-Log "              AD Daily Health Summary Complete!" -Level OK
    Write-Log "═══════════════════════════════════════════════════════════════════════════════" -Level OK
    Write-Log "📄 HTML Report : $htmlPath" -Level OK
    Write-Log "📊 DC CSV      : $dcCsv" -Level OK
    Write-Log "📋 Events CSV  : $eventCsv" -Level OK
    Write-Log "📦 JSON Report : $jsonPath" -Level OK
    Write-Log "═══════════════════════════════════════════════════════════════════════════════" -Level OK
    
    # Return output object
    [pscustomobject]@{
        HtmlReport = $htmlPath
        DcCsv = $dcCsv
        EventCsv = $eventCsv
        JsonReport = $jsonPath
        OverallStatus = $healthStatus
        EventCount = $allEvents.Count
        CriticalEventCount = @($allEvents | Where-Object { $_.Severity -eq 'Critical' }).Count
        FailedLogonCount = @($allEvents | Where-Object { $_.EventID -eq '4625' }).Count
    }
}
catch {
    Write-Log "FATAL ERROR: $($_.Exception.Message)" -Level ERROR
    Write-Log "Stack Trace: $($_.ScriptStackTrace)" -Level ERROR
    
    # Return error object instead of exiting
    [pscustomobject]@{
        Error = $_.Exception.Message
        StackTrace = $_.ScriptStackTrace
    }
}
